@model Webstore.Models.Order

<div class="order-details p-2">
    <div class="row mb-2">
        <div class="col-md-6">
            <strong>Đơn hàng #@Model.OrderId</strong><br />
            Ngày: @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")<br />
            Trạng thái: <span
                class="badge @(Model.Status switch { "Pending" => "bg-warning", "Processing" => "bg-info", "Shipped" => "bg-primary", "Completed" => "bg-success", "Cancelled" => "bg-danger", _ => "bg-secondary" })">@Model.Status</span>
        </div>
        <div class="col-md-6 text-end">
            Tài khoản: @Model.Account?.Username <br />
            Tổng tiền: @Model.TotalAmount.ToString("N2")
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-bordered mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:80px;">Ảnh</th>
                    <th>Sản phẩm</th>
                    <th style="width:100px;">Số lượng</th>
                    <th style="width:120px;">Đơn giá</th>
                    <th style="width:120px;">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var it in Model.OrderItems)
                {
                    <tr>
                        <td class="text-center">
                            @if (it.Product != null && !string.IsNullOrEmpty(it.Product.ImageUrl))
                            {
                                <img src="@it.Product.ImageUrl" alt="@it.Product.Name"
                                    style="width: 70px; height: 70px; object-fit: contain; border-radius: 4px;" />
                            }
                            else
                            {
                                <div class="text-muted"
                                    style="width: 70px; height: 70px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-box"></i>
                                </div>
                            }
                        </td>
                        <td>
                            @if (it.Product != null)
                            {
                                <a asp-controller="Shop" asp-action="Product" asp-route-id="@it.ProductId">@it.Product.Name</a>
                            }
                            else
                            {
                                @it.ProductId
                            }
                        </td>
                        <td>@it.Quantity</td>
                        <td>@it.UnitPrice.ToString("N2")</td>
                        <td>@(it.UnitPrice* it.Quantity).ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="mt-2"><strong>Ghi chú:</strong> @Model.Notes</div>
    }
</div>