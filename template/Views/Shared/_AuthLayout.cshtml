<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Webstore</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --primary: #0077B6;
            --primary-dark: #005f8a;
            --primary-light: #00B4D8;
            --primary-lighter: #90E0EF;
            --primary-lightest: #CAF0F8;
            --accent: #023E8A;
            --accent-light: #0096C7;
            --surface: #ffffff;
            --surface-alt: #F0F8FF;
            --text-primary: #1a1a2e;
            --text-secondary: #5C6B7A;
            --text-muted: #9CA8B3;
            --border: #E1E8ED;
            --success: #10B981;
            --danger: #EF4444;
            --warning: #F59E0B;
            --info: #3B82F6;
            --shadow-sm: 0 1px 3px rgba(0, 119, 182, 0.08);
            --shadow-md: 0 4px 12px rgba(0, 119, 182, 0.12);
            --shadow-lg: 0 8px 30px rgba(0, 119, 182, 0.15);
            --shadow-xl: 0 20px 60px rgba(0, 119, 182, 0.2);
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 16px;
            --radius-xl: 24px;
            --transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: linear-gradient(135deg, var(--accent) 0%, var(--primary) 50%, var(--primary-light) 100%);
            min-height: 100vh;
        }

        a { text-decoration: none; color: inherit; transition: var(--transition); }
        a:hover { color: var(--primary); }

        /* Back to home button */
        .back-to-home {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 1000;
        }

        .back-to-home .btn {
            background: rgba(255, 255, 255, 0.15);
            border: 2px solid rgba(255, 255, 255, 0.3);
            color: white;
            backdrop-filter: blur(10px);
            transition: var(--transition);
            border-radius: var(--radius-md);
            padding: 8px 16px;
            font-weight: 600;
            font-size: 0.88rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .back-to-home .btn:hover {
            background: rgba(255, 255, 255, 0.25);
            border-color: rgba(255, 255, 255, 0.5);
            transform: translateY(-2px);
            color: white;
        }

        /* Auth Container */
        .auth-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 80px 20px 40px;
            position: relative;
            overflow: hidden;
        }

        .auth-container::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 60%);
            animation: pulseGlow 8s ease-in-out infinite;
            pointer-events: none;
        }

        @@keyframes pulseGlow {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.1); opacity: 0.7; }
        }

        /* Auth Card */
        .auth-card {
            background: white;
            border-radius: var(--radius-xl);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.15);
            padding: 48px 40px;
            width: 100%;
            max-width: 460px;
            animation: slideUp 0.6s ease-out;
            position: relative;
            z-index: 1;
            border: 1px solid rgba(255,255,255,0.2);
        }

        /* SlideUp animation */
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .auth-header {
            text-align: center;
            margin-bottom: 32px;
        }

        .auth-logo {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .auth-icon-wrapper {
            width: 72px;
            height: 72px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            border-radius: var(--radius-lg);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            color: white;
            font-size: 1.8rem;
            box-shadow: 0 8px 25px rgba(0, 119, 182, 0.35);
        }

        .auth-title {
            color: var(--accent);
            font-weight: 800;
            margin-bottom: 6px;
            font-size: 1.6rem;
        }

        .auth-subtitle {
            color: var(--text-secondary);
            margin-bottom: 0;
            font-size: 0.92rem;
        }

        /* Auth Form */
        .auth-form {
            display: flex;
            flex-direction: column;
        }

        .input-group-custom {
            position: relative;
        }

        .input-icon-wrapper {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 1rem;
            z-index: 2;
            transition: var(--transition);
            pointer-events: none;
        }

        .input-with-icon {
            width: 100%;
            border: 2px solid var(--border);
            border-radius: var(--radius-md);
            padding: 14px 16px 14px 48px;
            font-size: 0.95rem;
            font-family: 'Be Vietnam Pro', sans-serif;
            transition: var(--transition);
            background: var(--surface-alt);
            color: var(--text-primary);
        }

        .input-with-icon:focus {
            outline: none;
            border-color: var(--primary);
            background: white;
            box-shadow: 0 0 0 4px rgba(0, 119, 182, 0.1);
        }

        .input-group-custom:focus-within .input-icon-wrapper {
            color: var(--primary);
        }

        /* Form Control */
        .form-control {
            border: 2px solid var(--border);
            border-radius: var(--radius-md);
            padding: 12px 16px;
            transition: var(--transition);
            font-size: 0.95rem;
            font-family: 'Be Vietnam Pro', sans-serif;
        }

        .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(0, 119, 182, 0.1);
        }

        /* Checkbox */
        .form-check-custom {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .form-check-input-custom {
            width: 18px;
            height: 18px;
            accent-color: var(--primary);
            cursor: pointer;
            flex-shrink: 0;
        }

        .form-check-label-custom {
            color: var(--text-secondary);
            font-weight: 500;
            font-size: 0.88rem;
            cursor: pointer;
            line-height: 1.5;
        }

        /* Forgot link */
        .forgot-link {
            color: var(--primary);
            font-weight: 600;
            font-size: 0.85rem;
            transition: var(--transition);
            text-decoration: none;
        }

        .forgot-link:hover {
            color: var(--primary-dark);
            text-decoration: underline;
        }

        /* Submit button */
        .btn-auth-submit {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: white;
            border: none;
            border-radius: var(--radius-md);
            font-size: 1rem;
            font-weight: 700;
            font-family: 'Be Vietnam Pro', sans-serif;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 4px 15px rgba(0, 119, 182, 0.3);
        }

        .btn-auth-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 119, 182, 0.4);
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);
            color: white;
        }

        .btn-auth-submit:active {
            transform: translateY(0);
        }

        /* Buttons */
        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            border: none;
            border-radius: var(--radius-md);
            padding: 14px;
            font-weight: 700;
            font-family: 'Be Vietnam Pro', sans-serif;
            transition: var(--transition);
            box-shadow: 0 4px 15px rgba(0, 119, 182, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 119, 182, 0.4);
            color: white;
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);
        }

        .btn-success {
            background: linear-gradient(135deg, var(--success) 0%, #34D399 100%);
            border: none;
            border-radius: var(--radius-md);
            padding: 14px;
            font-weight: 700;
            font-family: 'Be Vietnam Pro', sans-serif;
            transition: var(--transition);
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
        }

        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(16, 185, 129, 0.4);
            color: white;
        }

        /* Links */
        .text-link {
            color: var(--primary);
            font-weight: 700;
            text-decoration: none;
            transition: var(--transition);
        }

        .text-link:hover {
            color: var(--primary-dark);
            text-decoration: underline;
        }

        /* Alerts */
        .alert-msg {
            padding: 12px 16px;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
        }

        .alert-danger-msg {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .alert-success-msg {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .text-danger {
            font-size: 0.82rem;
            margin-top: 4px;
            color: var(--danger) !important;
        }

        .auth-form-footer {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        .alert-info-auth {
            background: rgba(0, 119, 182, 0.1);
            color: var(--primary);
            border: 1px solid rgba(0, 119, 182, 0.2);
            border-radius: var(--radius-md);
            padding: 12px 16px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .btn-success-submit {
            background: linear-gradient(135deg, var(--success) 0%, #34D399 100%);
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
            border: none;
            border-radius: var(--radius-md);
            padding: 14px;
            font-weight: 700;
            font-family: 'Be Vietnam Pro', sans-serif;
            transition: var(--transition);
            color: white;
            width: 100%;
            cursor: pointer;
        }

        .btn-success-submit:hover {
            transform: translateY(-2px);
            background: linear-gradient(135deg, #059669 0%, var(--success) 100%);
            box-shadow: 0 8px 25px rgba(16, 185, 129, 0.4);
            color: white;
        }

        .auth-icon-success {
            background: linear-gradient(135deg, var(--success) 0%, #34D399 100%);
            box-shadow: 0 8px 25px rgba(16, 185, 129, 0.35);
        }

        .form-check-input:checked {
            background-color: var(--primary);
            border-color: var(--primary);
        }

        .form-check-label {
            color: var(--text-secondary);
            font-weight: 500;
        }

        /* Responsive */
        @@media (max-width: 575px) {
            .auth-card {
                padding: 36px 24px;
            }
            .auth-title { font-size: 1.4rem; }
            .auth-icon-wrapper {
                width: 60px;
                height: 60px;
                font-size: 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="back-to-home">
        <a asp-controller="Shop" asp-action="Index" class="btn">
            <i class="fas fa-arrow-left"></i>Về trang chủ
        </a>
    </div>

    <main>
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    <script src="~/js/site.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const forms = document.querySelectorAll('form');
            forms.forEach(form => {
                form.addEventListener('submit', function() {
                    const submitBtn = this.querySelector('button[type="submit"]');
                    if (submitBtn && !submitBtn.disabled) {
                        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...';
                        submitBtn.disabled = true;
                    }
                });
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
