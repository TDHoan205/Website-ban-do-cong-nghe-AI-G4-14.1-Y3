<!-- ================================================ -->
<!-- REUSABLE PAGINATION + PAGE SIZE CONTROL COMPONENT -->
<!-- Bảng điều khiển phân trang + số dòng mỗi trang   -->
<!-- ================================================ -->
@model Webstore.ViewComponents.PagerViewModel

@if (Model.TotalPages <= 0)
{
    return;
}

<div class="data-table-footer @Model.ContainerClass">
    <!-- Hàng 1: Số dòng/trang — nằm bên trái -->
    <div class="page-size-control mb-2">
        <label class="text-muted mb-0">
            <i class="fas fa-list-ol me-1"></i>Số dòng/trang:
        </label>
        <select class="form-select form-select-sm page-size-select"
                style="width: 200px;"
                onchange="window.location.href=this.value">
            @foreach (var opt in new[] { 5, 10, 20, 50, 100, 250, 500 })
            {
                var url = Model.GetPageSizeUrl(opt);
                <option value="@url" selected="@(Model.PageSize == opt)">@opt</option>
            }
        </select>
    </div>

    <!-- Hàng 2: Các nút mũi tên phân trang -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Phân trang" class="pagination-nav mb-2">
            <ul class="pagination mb-0 justify-content-center">

                @* First page *@
                @if (Model.HasPrevious)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Model.GetPageUrl(1)" title="Trang đầu" aria-label="Trang đầu">
                            <i class="fas fa-angle-double-left" aria-hidden="true"></i>
                        </a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="@Model.GetPageUrl(Model.CurrentPage - 1)" title="Trang trước" aria-label="Trang trước">
                            <i class="fas fa-angle-left" aria-hidden="true"></i>
                        </a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled" aria-disabled="true">
                        <span class="page-link"><i class="fas fa-angle-double-left" aria-hidden="true"></i></span>
                    </li>
                    <li class="page-item disabled" aria-disabled="true">
                        <span class="page-link"><i class="fas fa-angle-left" aria-hidden="true"></i></span>
                    </li>
                }

                @* Page numbers — sliding window algorithm *@
                @{
                    int windowSize = 5;
                    int halfWindow = windowSize / 2;
                    int start = Math.Max(1, Model.CurrentPage - halfWindow);
                    int end = Math.Min(Model.TotalPages, Model.CurrentPage + halfWindow);

                    if (end - start < windowSize - 1)
                    {
                        if (start == 1)
                            end = Math.Min(Model.TotalPages, start + windowSize - 1);
                        else
                            start = Math.Max(1, end - windowSize + 1);
                    }

                    if (start > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Model.GetPageUrl(1)">1</a>
                        </li>
                        @if (start > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }

                    for (int i = start; i <= end; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")" aria-current="@(i == Model.CurrentPage ? "page" : null)">
                            <a class="page-link" href="@Model.GetPageUrl(i)">@i</a>
                        </li>
                    }

                    if (end < Model.TotalPages)
                    {
                        @if (end < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="@Model.GetPageUrl(Model.TotalPages)">@Model.TotalPages</a>
                        </li>
                    }
                }

                @* Next page *@
                @if (Model.HasNext)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Model.GetPageUrl(Model.CurrentPage + 1)" title="Trang sau" aria-label="Trang sau">
                            <i class="fas fa-angle-right" aria-hidden="true"></i>
                        </a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="@Model.GetPageUrl(Model.TotalPages)" title="Trang cuối" aria-label="Trang cuối">
                            <i class="fas fa-angle-double-right" aria-hidden="true"></i>
                        </a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled" aria-disabled="true">
                        <span class="page-link"><i class="fas fa-angle-right" aria-hidden="true"></i></span>
                    </li>
                    <li class="page-item disabled" aria-disabled="true">
                        <span class="page-link"><i class="fas fa-angle-double-right" aria-hidden="true"></i></span>
                    </li>
                }
            </ul>
        </nav>
    }

    <!-- Hàng 3: Thông tin hiển thị -->
    <div class="page-info-compact text-center">
        <span class="text-muted">
            <i class="fas fa-database me-1"></i>
            Hiển thị <strong>@(((Model.CurrentPage - 1) * Model.PageSize) + 1)</strong>
            – <strong>@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount).ToString("N0"))</strong>
            trong <strong>@Model.TotalCount.ToString("N0")</strong> bản ghi
        </span>
    </div>
</div>
