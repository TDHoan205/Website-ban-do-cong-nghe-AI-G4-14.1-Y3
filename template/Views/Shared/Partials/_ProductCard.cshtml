@model Webstore.Models.Product

<div class="product-card-wrapper">
    <div class="product-card-modern" data-product-id="@Model.ProductId">
        <div class="product-image-wrapper">
            <a asp-controller="Shop" asp-action="Product" asp-route-id="@Model.ProductId" class="product-image-link">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="product-main-img" loading="lazy" />
                }
                else
                {
                    <div class="product-placeholder">
                        <i class="fas fa-laptop"></i>
                    </div>
                }
            </a>
            
            <div class="product-badges">
                @if (Model.IsNew)
                {
                    <span class="badge-new-sm">
                        <i class="fas fa-bolt me-1"></i>Mới
                    </span>
                }
                @if (Model.IsHot)
                {
                    <span class="badge-hot-sm">
                        <i class="fas fa-fire me-1"></i>Hot
                    </span>
                }
                @if (Model.DiscountPercent > 0 || (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.Price))
                {
                    var discountPercent = Model.DiscountPercent > 0 ? Model.DiscountPercent : (int)((1 - Model.Price / Model.OriginalPrice!.Value) * 100);
                    <span class="badge-sale-sm">-@discountPercent%</span>
                }
            </div>

            <div class="product-quick-actions">
                <button class="quick-action-btn" onclick="addToCart(@Model.ProductId)" title="Thêm vào giỏ hàng">
                    <i class="fas fa-cart-plus"></i>
                </button>
                <a asp-controller="Shop" asp-action="Product" asp-route-id="@Model.ProductId" class="quick-action-btn" title="Xem chi tiết">
                    <i class="fas fa-eye"></i>
                </a>
            </div>
        </div>

        <div class="product-content">
            @if (Model.Category != null)
            {
                <div class="product-category-sm">@Model.Category.Name</div>
            }
            
            <h3 class="product-name-sm">
                <a asp-controller="Shop" asp-action="Product" asp-route-id="@Model.ProductId">
                    @Model.Name
                </a>
            </h3>

            @if (Model.Rating > 0)
            {
                <div class="product-rating-sm">
                    <div class="rating-stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Floor(Model.Rating))
                            {
                                <i class="fas fa-star"></i>
                            }
                            else if (i - 0.5m <= Model.Rating)
                            {
                                <i class="fas fa-star-half-alt"></i>
                            }
                            else
                            {
                                <i class="far fa-star"></i>
                            }
                        }
                    </div>
                    <span class="rating-value">@Model.Rating.ToString("0.0")</span>
                </div>
            }

            <div class="product-price-section">
                @if (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.Price)
                {
                    <div class="price-wrapper">
                        <span class="price-current-sm">@Model.Price.ToString("N0")đ</span>
                        <span class="price-original-sm">@Model.OriginalPrice.Value.ToString("N0")đ</span>
                    </div>
                }
                else
                {
                    <div class="price-wrapper">
                        <span class="price-current-sm">@Model.Price.ToString("N0")đ</span>
                    </div>
                }
            </div>

            <button class="btn-add-cart-sm w-100" onclick="addToCart(@Model.ProductId)">
                <i class="fas fa-shopping-cart me-2"></i>Thêm vào giỏ hàng
            </button>
        </div>
    </div>
</div>


@functions {
    public string GetColorHex(string colorName) {
        if (string.IsNullOrEmpty(colorName)) return "#ccc";
        colorName = colorName.ToLower();
        if (colorName.Contains("đen") || colorName.Contains("black")) return "#333";
        if (colorName.Contains("trắng") || colorName.Contains("white")) return "#fff";
        if (colorName.Contains("xanh") || colorName.Contains("blue")) return "#3b82f6";
        if (colorName.Contains("hồng") || colorName.Contains("pink")) return "#f472b6";
        if (colorName.Contains("vàng") || colorName.Contains("gold")) return "#fbbf24";
        if (colorName.Contains("bạc") || colorName.Contains("silver")) return "#e2e8f0";
        if (colorName.Contains("titan")) return "#71717a";
        return "#ddd";
    }
}
