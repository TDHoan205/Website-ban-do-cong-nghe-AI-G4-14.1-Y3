@model Webstore.Models.ReceiptShipment
@{
    ViewData["Title"] = "Thêm Nhật Ký Nhập/Xuất Kho";
    var products = ViewBag.Products as List<Webstore.Models.Product> ?? new List<Webstore.Models.Product>();
    var orders = ViewBag.Orders as List<Webstore.Models.Order> ?? new List<Webstore.Models.Order>();
}

<h2>Thêm Nhật Ký Nhập/Xuất Kho</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="ProductId" class="form-label">Sản phẩm</label>
        <select asp-for="ProductId" class="form-select">
            <option value="">-- Chọn sản phẩm --</option>
            @foreach (var p in products)
            {
                <option value="@p.ProductId">@p.Name</option>
            }
        </select>
        <span asp-validation-for="ProductId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="MovementType" class="form-label">Loại</label>
        <select asp-for="MovementType" class="form-select">
            <option value="">-- Chọn loại --</option>
            <option value="IN">NHẬP KHO</option>
            <option value="OUT">XUẤT KHO</option>
        </select>
        <span asp-validation-for="MovementType" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Quantity" class="form-label">Số lượng</label>
        <input asp-for="Quantity" class="form-control" type="number" min="1" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="MovementDate" class="form-label">Ngày</label>
        <input asp-for="MovementDate" class="form-control" type="datetime-local" />
        <span asp-validation-for="MovementDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="RelatedOrderId" class="form-label">Đơn hàng liên quan (tùy chọn)</label>
        <select asp-for="RelatedOrderId" class="form-select">
            <option value="">-- Không chọn --</option>
            @foreach (var o in orders)
            {
                <option value="@o.OrderId">Đơn hàng #@o.OrderId - @o.Account?.Username (@o.OrderDate.ToString("dd/MM/yyyy"))</option>
            }
        </select>
    </div>
    <button type="submit" class="btn btn-success">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
