@{
    ViewData["Title"] = "Quản lý dữ liệu mẫu";
}

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-database me-2"></i>Quản lý dữ liệu mẫu</h2>
                        <form asp-action="ResetData" method="post" class="d-inline">
                            <button type="submit" class="btn btn-warning" onclick="return confirm('Bạn có chắc muốn reset toàn bộ dữ liệu?')">
                                <i class="fas fa-trash me-2"></i>Reset dữ liệu
                            </button>
                        </form>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Tài khoản -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-users me-2"></i>Tài khoản (@ViewBag.Accounts.Count)</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Username</th>
                                    <th>Mật khẩu</th>
                                    <th>Họ tên</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Phone</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var account in ViewBag.Accounts)
                                {
                                    <tr>
                                        <td>@account.AccountId</td>
                                        <td><strong>@account.Username</strong></td>
                                        <td><code>@account.PasswordHash</code></td>
                                        <td>@account.FullName</td>
                                        <td>@account.Email</td>
                                        <td>
                                            <span class="badge bg-@(account.RoleName == "Admin" ? "danger" : account.RoleName == "Employee" ? "warning" : "info")">
                                                @account.RoleName
                                            </span>
                                        </td>
                                        <td>@account.Phone</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Danh mục -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-tags me-2"></i>Danh mục (@ViewBag.Categories.Count)</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Tên</th>
                                    <th>Mô tả</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var category in ViewBag.Categories)
                                {
                                    <tr>
                                        <td>@category.CategoryId</td>
                                        <td><strong>@category.Name</strong></td>
                                        <td>@category.Description</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Nhà cung cấp -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-truck me-2"></i>Nhà cung cấp (@ViewBag.Suppliers.Count)</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Tên</th>
                                    <th>Liên hệ</th>
                                    <th>Địa chỉ</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var supplier in ViewBag.Suppliers)
                                {
                                    <tr>
                                        <td>@supplier.SupplierId</td>
                                        <td><strong>@supplier.Name</strong></td>
                                        <td>@supplier.ContactInfo</td>
                                        <td>@supplier.Address</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Sản phẩm -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-box me-2"></i>Sản phẩm (@ViewBag.Products.Count)</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Tên</th>
                                    <th>Giá</th>
                                    <th>Mô tả</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in ViewBag.Products)
                                {
                                    <tr>
                                        <td>@product.ProductId</td>
                                        <td><strong>@product.Name</strong></td>
                                        <td>@product.Price.ToString("N0") ₫</td>
                                        <td>@Html.Raw(ProductDescriptionText.SanitizeDescriptionHtml(product.Description))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Thông tin đăng nhập mẫu -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-key me-2"></i>Thông tin đăng nhập mẫu</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="card border-danger">
                                <div class="card-header bg-danger text-white">
                                    <h6 class="mb-0">Admin</h6>
                                </div>
                                <div class="card-body">
                                    <p><strong>Username:</strong> admin</p>
                                    <p><strong>Password:</strong> admin123</p>
                                    <p><strong>Quyền:</strong> Quản trị toàn bộ hệ thống</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-warning">
                                <div class="card-header bg-warning text-dark">
                                    <h6 class="mb-0">Employee</h6>
                                </div>
                                <div class="card-body">
                                    <p><strong>Username:</strong> employee</p>
                                    <p><strong>Password:</strong> employee123</p>
                                    <p><strong>Quyền:</strong> Quản lý sản phẩm, đơn hàng, kho</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-info">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0">Customer</h6>
                                </div>
                                <div class="card-body">
                                    <p><strong>Username:</strong> customer</p>
                                    <p><strong>Password:</strong> customer123</p>
                                    <p><strong>Quyền:</strong> Mua sắm trong cửa hàng</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        box-shadow: var(--shadow-sm);
        border: none;
    }

    .card-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        color: white;
        border: none;
    }

    .table th {
        background-color: var(--surface-alt);
        border-top: none;
        font-weight: 600;
    }

    .badge {
        font-size: 0.8rem;
        border-radius: var(--radius-sm);
    }

    code {
        background-color: var(--surface-alt);
        padding: 2px 6px;
        border-radius: var(--radius-sm);
        font-size: 0.9rem;
    }
</style>
