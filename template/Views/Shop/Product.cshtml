@model Webstore.Models.Product
@using System.Text.Json
@{
    ViewData["Title"] = Model.Name;
    Layout = "_ShopLayout";

    var fallbackDescriptionHtml = Webstore.Utilities.ProductDescriptionText.SanitizeDescriptionHtml(
        "Sản phẩm chất lượng cao với thiết kế hiện đại, phù hợp cho mọi nhu cầu sử dụng. Được sản xuất với công nghệ tiên tiến và vật liệu cao cấp.");
    var descriptionHtml = string.IsNullOrWhiteSpace(Model.Description) ? fallbackDescriptionHtml : Model.Description;

    // Lấy ProductDetailDto từ ViewBag
    var detail = ViewBag.ProductDetail as Webstore.Models.DTOs.ProductDetailDto;
    var imagesByVariant = detail?.ImagesByVariant ?? new Dictionary<string, List<Webstore.Models.ProductImage>>();
    var allImages = detail?.AllImages ?? new List<Webstore.Models.ProductImage>();

    // Chuyển đổi thành dictionary cho JS: key = "variantId" | "default"
    // Mỗi image cần: imageId, imageUrl, isPrimary, isThumbnail, displayOrder
    var jsImagesByVariant = imagesByVariant.ToDictionary(
        kvp => kvp.Key,
        kvp => (object)kvp.Value.Select(pi => new {
            imageId = pi.ImageId,
            imageUrl = pi.ImageUrl,
            variantId = pi.VariantId,
            isPrimary = pi.IsPrimary,
            isThumbnail = pi.IsThumbnail,
            displayOrder = pi.DisplayOrder,
            altText = pi.AltText ?? ""
        }).ToList()
    );

    // Fallback: nếu không có ảnh nào, dùng placeholder
    if (jsImagesByVariant.Count == 0)
    {
        var placeholderImg = new { imageId = 0, imageUrl = "/images/products/placeholder.svg", variantId = (int?)null, isPrimary = true, isThumbnail = true, displayOrder = 0, altText = "Hình ảnh sản phẩm" };
        var placeholderList = new List<object>();
        placeholderList.Add(placeholderImg);
        jsImagesByVariant["default"] = (object)placeholderList;
    }

    var jsImagesJson = System.Text.Json.JsonSerializer.Serialize(jsImagesByVariant);
    var defaultImagesList = jsImagesByVariant.ContainsKey("default") ? jsImagesByVariant["default"] : (object)new List<object>();
    var defaultImagesJson = System.Text.Json.JsonSerializer.Serialize(defaultImagesList);
    var productJson = new {
        productId = Model.ProductId,
        name = Model.Name,
        price = Model.Price,
        originalPrice = Model.OriginalPrice,
        discountPercent = Model.DiscountPercent,
        stockQuantity = Model.StockQuantity,
        categoryName = Model.Category?.Name ?? "",
        supplierName = Model.Supplier?.Name ?? "",
        imageUrl = Model.ImageUrl ?? ""
    };
    var productJsonStr = System.Text.Json.JsonSerializer.Serialize(productJson);

    // Variant JSON
    var variantList = (Model.Variants ?? new List<Webstore.Models.ProductVariant>()).Select(v => new {
        variantId = v.VariantId,
        color = v.Color ?? "",
        storage = v.Storage ?? "",
        ram = v.RAM ?? "",
        config = (v.Storage ?? "") + (string.IsNullOrEmpty(v.RAM) ? "" : " / " + v.RAM),
        price = v.Price,
        originalPrice = v.OriginalPrice,
        stockQuantity = v.StockQuantity
    }).ToList();
    var variantJson = System.Text.Json.JsonSerializer.Serialize(variantList);

    // Unique colors & configs for UI
    var uniqueColors = (Model.Variants ?? new List<Webstore.Models.ProductVariant>())
        .Where(v => !string.IsNullOrEmpty(v.Color))
        .Select(v => v.Color!)
        .Distinct()
        .ToList();
    var uniqueConfigs = (Model.Variants ?? new List<Webstore.Models.ProductVariant>())
        .Where(v => !string.IsNullOrEmpty(v.Storage) || !string.IsNullOrEmpty(v.RAM))
        .Select(v => new { key = (v.Storage ?? "") + (string.IsNullOrEmpty(v.RAM) ? "" : " / " + v.RAM), storage = v.Storage ?? "", ram = v.RAM ?? "" })
        .Where(x => !string.IsNullOrEmpty(x.key))
        .DistinctBy(x => x.key)
        .ToList();
}

<!-- Page Header -->
<div class="page-header-sm">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-light">
                <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Products">Sản phẩm</a></li>
                <li class="breadcrumb-item"><a asp-controller="Shop" asp-action="Products" asp-route-categoryId="@Model.CategoryId">@(Model.Category?.Name ?? "Danh mục")</a></li>
                <li class="breadcrumb-item active">@(Model.Name)</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-5">
    <div class="row">
        <!-- ===================== PRODUCT IMAGE GALLERY (SHOPEE-STYLE) ===================== -->
        <div class="col-lg-6 mb-4">
            <div class="product-gallery-container">

                <!-- Main Image Display -->
                <div class="gallery-main" id="galleryMain">
                    <!-- Prev/Next Buttons -->
                    <button class="nav-btn prev" id="btnPrev" onclick="prevSlide()"><i class="fas fa-chevron-left"></i></button>
                    <button class="nav-btn next" id="btnNext" onclick="nextSlide()"><i class="fas fa-chevron-right"></i></button>

                    <!-- The main image -->
                    <div class="main-image-wrapper" id="mainImageWrapper">
                        <img id="mainImg" src="/images/products/placeholder.svg" alt="@Model.Name" />
                    </div>

                    <!-- Image counter -->
                    <div class="img-counter" id="imgCounter">
                        <span id="currentImgIdx">1</span> / <span id="totalImgCount">1</span>
                    </div>

                    <!-- Zoom lens -->
                    <div class="zoom-lens" id="zoomLens"></div>
                    <!-- Zoom result -->
                    <div id="zoomResult" class="zoom-result"></div>
                </div>

                <!-- Thumbnails -->
                <div class="gallery-thumbs" id="thumbContainer">
                    <!-- Rendered by JS -->
                </div>

                <!-- Gallery label -->
                <div class="gallery-label">
                    <i class="fas fa-images me-1"></i> Nhấn giữ ảnh để phóng to
                </div>
            </div>
        </div>

        <!-- ===================== PRODUCT INFO ===================== -->
        <div class="col-lg-6">
            <div class="product-detail-card">
                <div class="detail-header">
                    <div class="detail-category">@Model.Category?.Name</div>
                    <h1 class="detail-title">@Model.Name</h1>
                    <div class="detail-rating">
                        <span class="stars">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star-half-alt"></i>
                        </span>
                        <span class="rating-text">4.5 (128 đánh giá)</span>
                    </div>
                </div>

                <div class="detail-price-section" id="priceSection">
                    <div class="detail-price" id="displayPrice">@Model.Price.ToString("N0") ₫</div>
                    <div id="displayOriginalPrice"></div>
                </div>

                <!-- ====== CONFIG (RAM/ROM) ====== -->
                @if (uniqueConfigs.Any())
                {
                    <div class="variant-group mb-3">
                        <label class="variant-label">
                            <i class="fas fa-microchip me-1"></i> Phiên bản:
                        </label>
                        <div class="variant-options d-flex flex-wrap gap-2" id="configOptions">
                            @foreach (var cfg in uniqueConfigs)
                            {
                                <button type="button" class="btn variant-option-btn config-btn"
                                        data-config="@cfg.key"
                                        data-storage="@cfg.storage"
                                        data-ram="@cfg.ram"
                                        onclick="selectConfig('@cfg.key')">
                                    @cfg.key
                                </button>
                            }
                        </div>
                    </div>
                }

                <!-- ====== COLOR ====== -->
                @if (uniqueColors.Any())
                {
                    <div class="variant-group mb-3">
                        <label class="variant-label">
                            <i class="fas fa-palette me-1"></i> Màu sắc:
                        </label>
                        <div class="variant-options d-flex flex-wrap gap-2" id="colorOptions">
                            @foreach (var color in uniqueColors)
                            {
                                <button type="button" class="btn variant-option-btn color-btn"
                                        data-color="@color"
                                        onclick="selectColor('@color')">
                                    @color
                                </button>
                            }
                        </div>
                    </div>
                }

                <!-- Selected variant summary -->
                <div class="selected-variant-summary" id="selectedVariantSummary" style="display:none;">
                    <i class="fas fa-check-circle text-success me-1"></i>
                    <span id="selectedVariantText"></span>
                </div>

                <!-- Description -->
                <div class="detail-desc">
                    <h6><i class="fas fa-info-circle me-2"></i>Mô tả sản phẩm</h6>
                    <div class="product-description-content">@Html.Raw(descriptionHtml)</div>
                </div>

                <!-- Stock status -->
                <div class="detail-meta">
                    <div class="meta-item">
                        <i class="fas fa-check-circle text-success" id="stockStatusIcon"></i>
                        <span id="stockStatusText">@(Model.StockQuantity > 0 ? "Còn hàng" : "Hết hàng")</span>
                    </div>
                </div>

                <!-- Quantity -->
                <div class="detail-quantity">
                    <label class="qty-label">Số lượng</label>
                    <div class="qty-controls">
                        <button type="button" class="qty-btn" onclick="decreaseQty()"><i class="fas fa-minus"></i></button>
                        <input type="number" id="quantity" class="qty-input" value="1" min="1" max="10" readonly>
                        <button type="button" class="qty-btn" onclick="increaseQty()"><i class="fas fa-plus"></i></button>
                    </div>
                    <span class="stock-note" id="stockNote">@(Model.StockQuantity > 0 ? $"{Model.StockQuantity} sản phẩm có sẵn" : "")</span>
                </div>

                <!-- Actions -->
                <div class="detail-actions">
                    <button class="btn btn-add-to-cart" id="btnAddToCart" onclick="addToCartWithQty()">
                        <i class="fas fa-cart-plus me-2"></i>Thêm vào giỏ hàng
                    </button>
                    <button class="btn btn-buy-now" onclick="buyNow()">
                        <i class="fas fa-bolt me-2"></i>Mua ngay
                    </button>
                </div>

                <!-- Features -->
                <div class="detail-features">
                    <div class="feature-row">
                        <div class="feature-icon-sm"><i class="fas fa-shipping-fast"></i></div>
                        <div>
                            <strong>Giao hàng nhanh</strong>
                            <small>Giao trong 24h nội thành</small>
                        </div>
                    </div>
                    <div class="feature-row">
                        <div class="feature-icon-sm"><i class="fas fa-shield-alt"></i></div>
                        <div>
                            <strong>Bảo hành 12 tháng</strong>
                            <small>Chính hãng toàn quốc</small>
                        </div>
                    </div>
                    <div class="feature-row">
                        <div class="feature-icon-sm"><i class="fas fa-headset"></i></div>
                        <div>
                            <strong>Hỗ trợ 24/7</strong>
                            <small>Tư vấn mọi lúc</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ===================== TABS ===================== -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="product-tabs">
                <div class="tabs-header">
                    <button class="tab-btn active" data-tab="description">
                        <i class="fas fa-info-circle me-2"></i>Mô tả chi tiết
                    </button>
                    <button class="tab-btn" data-tab="specs">
                        <i class="fas fa-cogs me-2"></i>Thông số kỹ thuật
                    </button>
                    <button class="tab-btn" data-tab="reviews">
                        <i class="fas fa-star me-2"></i>Đánh giá (128)
                    </button>
                </div>
                <div class="tabs-content">
                    <div class="tab-pane active" id="description">
                        <div class="tab-content-card">
                            <h5>Mô tả chi tiết sản phẩm</h5>
                            <div class="product-description-content">@Html.Raw(descriptionHtml)</div>
                            <ul>
                                <li>Chất liệu cao cấp, bền đẹp theo thời gian</li>
                                <li>Thiết kế hiện đại, sang trọng</li>
                                <li>Dễ dàng sử dụng và bảo quản</li>
                                <li>Bảo hành chính hãng 12 tháng</li>
                            </ul>
                        </div>
                    </div>
                    <div class="tab-pane" id="specs">
                        <div class="tab-content-card">
                            <h5>Thông số kỹ thuật</h5>
                            <table class="specs-table">
                                <tr><td><strong>Danh mục</strong></td><td>@(Model.Category?.Name ?? "Không có")</td></tr>
                                <tr><td><strong>Nhà cung cấp</strong></td><td>@(Model.Supplier?.Name ?? "Không có")</td></tr>
                                <tr><td><strong>Mã sản phẩm</strong></td><td>#@Model.ProductId</td></tr>
                            </table>
                        </div>
                    </div>
                    <div class="tab-pane" id="reviews">
                        <div class="tab-content-card">
                            <div class="review-summary">
                                <div class="review-score">
                                    <div class="score-number">4.5</div>
                                    <div class="score-stars">
                                        <i class="fas fa-star"></i><i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i><i class="fas fa-star"></i>
                                        <i class="fas fa-star-half-alt"></i>
                                    </div>
                                    <div class="score-count">128 đánh giá</div>
                                </div>
                            </div>
                            <hr>
                            <div class="review-item">
                                <div class="reviewer-info">
                                    <div class="reviewer-avatar">N</div>
                                    <div>
                                        <strong>Nguyễn Văn A</strong>
                                        <div class="review-stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                                    </div>
                                </div>
                                <p class="review-text">Sản phẩm rất tốt, chất lượng cao. Giao hàng nhanh, đóng gói cẩn thận.</p>
                                <small class="text-muted">2 ngày trước</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Related Products -->
    @if (ViewBag.RelatedProducts != null && ((List<Webstore.Models.Product>)ViewBag.RelatedProducts).Any())
    {
        <div class="row mt-5">
            <div class="col-12">
                <div class="section-header">
                    <h2 class="section-title"><i class="fas fa-th-large"></i> Sản phẩm liên quan</h2>
                </div>
                <div class="row g-4">
                    @foreach (var product in ViewBag.RelatedProducts)
                    {
                        <div class="col-lg-3 col-md-6">
                            <div class="product-card">
                                <a asp-controller="Shop" asp-action="Product" asp-route-id="@product.ProductId" class="product-card-img">
                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" alt="@product.Name" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="img-placeholder">
                                            <i class="fas fa-box" style="font-size:3rem;"></i>
                                            <span class="placeholder-name">@(product.Name)</span>
                                        </div>
                                    }
                                </a>
                                <div class="product-card-body">
                                    <div class="product-card-cat">@product.Category?.Name</div>
                                    <h5 class="product-card-title">
                                        <a asp-controller="Shop" asp-action="Product" asp-route-id="@product.ProductId">@product.Name</a>
                                    </h5>
                                    <div class="product-card-price">@product.Price.ToString("N0") ₫</div>
                                    <button class="btn btn-add-cart" onclick="addToCart(@product.ProductId)">
                                        <i class="fas fa-cart-plus"></i> Thêm vào giỏ
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/homepage.css" />
}

@section Scripts {
    <script>
    // ==================== DATA ====================
    const PRODUCT = @Html.Raw(productJsonStr);
    const VARIANTS = @Html.Raw(variantJson);
    const IMAGES_BY_VARIANT = @Html.Raw(jsImagesJson);

    // State
    let selectedConfig = null;
    let selectedColor = null;
    let currentVariant = null;
    let currentSlideIndex = 0;
    let currentImages = [];  // Array of image objects for current variant

    // ==================== IMAGE SYSTEM ====================

    /**
     * Lấy danh sách ảnh cho variant đang chọn.
     * Priority: variant images > default images > product.ImageUrl > placeholder
     */
    function getImagesForVariant(variantId) {
        var variantKey = variantId ? "variant_" + variantId : null;

        // 1. Try variant-specific images
        if (variantKey && IMAGES_BY_VARIANT[variantKey] && IMAGES_BY_VARIANT[variantKey].length > 0) {
            return IMAGES_BY_VARIANT[variantKey];
        }

        // 2. Fallback: default (product-level) images
        if (IMAGES_BY_VARIANT["default"] && IMAGES_BY_VARIANT["default"].length > 0) {
            return IMAGES_BY_VARIANT["default"];
        }

        // 3. Fallback: product.ImageUrl
        if (PRODUCT.imageUrl) {
            return [{ imageId: 0, imageUrl: PRODUCT.imageUrl, isPrimary: true, isThumbnail: true }];
        }

        // 4. Ultimate fallback
        return [{ imageId: 0, imageUrl: "/images/products/placeholder.svg", isPrimary: true, isThumbnail: true }];
    }

    /**
     * Update toàn bộ gallery khi variant thay đổi.
     * Gọi khi user click color hoặc config.
     */
    function updateImages(variantId) {
        currentImages = getImagesForVariant(variantId);
        currentSlideIndex = 0;

        renderMainImage();
        renderThumbnails();
        updateSlideCounter();
        updateNavButtons();
        preloaderNextImages();
    }

    function renderMainImage() {
        var mainImg = document.getElementById('mainImg');
        if (!mainImg || currentImages.length === 0) return;

        var imgData = currentImages[currentSlideIndex];
        var newSrc = imgData.imageUrl;

        // Fade-out transition
        mainImg.style.opacity = '0';
        mainImg.style.transition = 'opacity 0.2s ease';

        setTimeout(function() {
            mainImg.src = newSrc;
            mainImg.alt = imgData.altText || PRODUCT.name;
            mainImg.style.opacity = '1';

            // Update zoom background
            updateZoomBackground(newSrc);
        }, 200);
    }

    function renderThumbnails() {
        var container = document.getElementById('thumbContainer');
        if (!container) return;

        container.innerHTML = currentImages.map(function(img, idx) {
            var isActive = idx === currentSlideIndex ? 'active' : '';
            var thumbSrc = img.imageUrl;
            return '<div class="thumb-item ' + isActive + '" data-index="' + idx + '" onclick="changeSlide(' + idx + ')">' +
                   '<img src="' + thumbSrc + '" alt="' + (img.altText || '') + '" onerror="this.src=\'/images/products/placeholder.svg\'" loading="lazy" />' +
                   '</div>';
        }).join('');

        // Scroll active thumb into view
        var activeThumb = container.querySelector('.thumb-item.active');
        if (activeThumb) {
            activeThumb.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
        }
    }

    function changeSlide(index) {
        if (index < 0) index = currentImages.length - 1;
        if (index >= currentImages.length) index = 0;

        currentSlideIndex = index;

        renderMainImage();
        updateThumbHighlight();
        updateSlideCounter();
        updateNavButtons();
    }

    function nextSlide() { changeSlide(currentSlideIndex + 1); }
    function prevSlide() { changeSlide(currentSlideIndex - 1); }

    function updateThumbHighlight() {
        var container = document.getElementById('thumbContainer');
        if (!container) return;
        container.querySelectorAll('.thumb-item').forEach(function(thumb, idx) {
            thumb.classList.toggle('active', idx === currentSlideIndex);
        });
    }

    function updateSlideCounter() {
        var counter = document.getElementById('imgCounter');
        if (counter) {
            document.getElementById('currentImgIdx').textContent = currentSlideIndex + 1;
            document.getElementById('totalImgCount').textContent = currentImages.length;
        }
    }

    function updateNavButtons() {
        var prevBtn = document.getElementById('btnPrev');
        var nextBtn = document.getElementById('btnNext');
        // Hide nav if only 1 image
        var hidden = currentImages.length <= 1;
        if (prevBtn) prevBtn.style.visibility = hidden ? 'hidden' : 'visible';
        if (nextBtn) nextBtn.style.visibility = hidden ? 'hidden' : 'visible';
    }

    // ==================== ZOOM ====================
    function updateZoomBackground(src) {
        var result = document.getElementById('zoomResult');
        if (result) result.style.backgroundImage = "url('" + src + "')";
    }

    function initZoomLogic() {
        var mainImg = document.getElementById('mainImg');
        var lens = document.getElementById('zoomLens');
        var result = document.getElementById('zoomResult');
        var container = document.getElementById('galleryMain');
        if (!mainImg || !container || window.innerWidth < 992) return;

        container.onmouseenter = function() {
            if (lens) lens.style.display = "block";
            if (result) { result.style.display = "block"; updateZoomBackground(mainImg.src); }
        };
        container.onmouseleave = function() {
            if (lens) lens.style.display = "none";
            if (result) result.style.display = "none";
        };
        container.onmousemove = function(e) {
            var rect = mainImg.getBoundingClientRect();
            var x = e.clientX - rect.left - lens.offsetWidth / 2;
            var y = e.clientY - rect.top - lens.offsetHeight / 2;
            x = Math.max(0, Math.min(x, mainImg.offsetWidth - lens.offsetWidth));
            y = Math.max(0, Math.min(y, mainImg.offsetHeight - lens.offsetHeight));
            lens.style.left = x + "px";
            lens.style.top = y + "px";
            var cx = result.offsetWidth / lens.offsetWidth;
            var cy = result.offsetHeight / lens.offsetHeight;
            result.style.backgroundPosition = "-" + (x * cx) + "px -" + (y * cy) + "px";
        };
    }

    // ==================== PRELOAD ====================
    function preloaderNextImages() {
        if (currentImages.length < 2) return;
        var nextIdx = (currentSlideIndex + 1) % currentImages.length;
        var img = new Image();
        img.src = currentImages[nextIdx].imageUrl;
    }

    // ==================== VARIANT SELECTION ====================

    /**
     * Tìm variant khớp với config + color đang chọn.
     */
    function findMatchingVariant() {
        return VARIANTS.find(function(v) {
            var configMatch = !selectedConfig || v.config === selectedConfig;
            var colorMatch = !selectedColor || v.color === selectedColor;
            return configMatch && colorMatch;
        }) || null;
    }

    function selectConfig(config) {
        selectedConfig = config;
        document.querySelectorAll('.config-btn').forEach(function(btn) {
            var isActive = btn.getAttribute('data-config') === config;
            btn.classList.toggle('active', isActive);
            btn.classList.toggle('btn-primary', isActive);
            btn.classList.toggle('btn-outline-primary', !isActive);
        });

        onVariantChange();
    }

    function selectColor(color) {
        selectedColor = color;
        document.querySelectorAll('.color-btn').forEach(function(btn) {
            var isActive = btn.getAttribute('data-color') === color;
            btn.classList.toggle('active', isActive);
            btn.classList.toggle('btn-secondary', isActive);
            btn.classList.toggle('btn-outline-secondary', !isActive);
        });

        onVariantChange();
    }

    function onVariantChange() {
        currentVariant = findMatchingVariant();
        var variantId = currentVariant ? currentVariant.variantId : null;

        // Update images
        updateImages(variantId);

        // Update price
        updatePrice();

        // Update stock
        updateStock();

        // Update selected summary
        updateSelectedSummary();
    }

    function updatePrice() {
        var displayPrice = document.getElementById('displayPrice');
        var displayOriginal = document.getElementById('displayOriginalPrice');
        if (!displayPrice) return;

        var price = currentVariant ? currentVariant.price : PRODUCT.price;
        var originalPrice = currentVariant ? currentVariant.originalPrice : PRODUCT.originalPrice;
        var discount = PRODUCT.discountPercent;

        displayPrice.textContent = price.toLocaleString('vi-VN') + ' ₫';

        if (originalPrice && originalPrice > price) {
            discount = Math.round((1 - price / originalPrice) * 100);
            displayOriginal.innerHTML = '<del class="text-muted">' + originalPrice.toLocaleString('vi-VN') + ' ₫</del>' +
                                      '<span class="badge bg-danger ms-2">-' + discount + '%</span>';
        } else {
            displayOriginal.innerHTML = '';
        }
    }

    function updateStock() {
        var stockIcon = document.getElementById('stockStatusIcon');
        var stockText = document.getElementById('stockStatusText');
        var stockNote = document.getElementById('stockNote');
        var cartBtn = document.getElementById('btnAddToCart');

        var stock = currentVariant ? currentVariant.stockQuantity : PRODUCT.stockQuantity;
        var inStock = stock > 0;

        if (stockIcon) stockIcon.className = inStock ? 'fas fa-check-circle text-success' : 'fas fa-times-circle text-danger';
        if (stockText) stockText.textContent = inStock ? 'Còn hàng (' + stock + ')' : 'Hết hàng';
        if (stockNote) stockNote.textContent = inStock ? stock + ' sản phẩm có sẵn' : '';
        if (cartBtn) cartBtn.disabled = !inStock;
    }

    function updateSelectedSummary() {
        var summary = document.getElementById('selectedVariantSummary');
        var text = document.getElementById('selectedVariantText');
        if (!summary || !text) return;

        var parts = [];
        if (selectedColor) parts.push('Màu: ' + selectedColor);
        if (selectedConfig) parts.push('Phiên bản: ' + selectedConfig);

        if (parts.length > 0) {
            text.textContent = parts.join(' · ');
            summary.style.display = '';
        } else {
            summary.style.display = 'none';
        }
    }

    // ==================== QUANTITY ====================
    function increaseQty() {
        var input = document.getElementById('quantity');
        var max = currentVariant ? currentVariant.stockQuantity : PRODUCT.stockQuantity;
        var val = parseInt(input.value);
        if (val < Math.min(max, 10)) input.value = val + 1;
    }
    function decreaseQty() {
        var input = document.getElementById('quantity');
        var val = parseInt(input.value);
        if (val > 1) input.value = val - 1;
    }

    // ==================== CART ====================
    // Fix: Chỉ gửi variantId khi có giá trị, KHÔNG gửi variantId=null
    function addToCartWithQty() {
        var productId = PRODUCT.productId;
        var qty = parseInt(document.getElementById('quantity').value);
        var variantId = currentVariant ? currentVariant.variantId : null;

        var ajaxData = { productId: productId, quantity: qty };
        if (variantId !== null && variantId !== undefined) {
            ajaxData.variantId = variantId;
        }

        $.ajax({
            url: '@Url.Action("AddToCart", "Shop")',
            type: 'POST',
            data: ajaxData,
            success: function(res) {
                if (res.success) {
                    showToast("Đã thêm vào giỏ hàng!");
                    updateCartBadge(res.cartCount);
                } else if (res.requireLogin) {
                    window.location.href = '@Url.Action("Login", "Auth")?returnUrl=' + encodeURIComponent(window.location.href);
                } else {
                    showToast(res.message || "Có lỗi xảy ra", "error");
                }
            },
            error: function(xhr, status, errorThrown) {
                // Xử lý lỗi HTTP (500, network, etc.) - KHÔNG redirect to login
                console.error('[AddToCart AJAX Error]', status, errorThrown, xhr.responseText);
                showToast("Có lỗi xảy ra khi thêm vào giỏ hàng. Vui lòng thử lại.", "error");
            }
        });
    }

    function addToCart(productId) {
        $.ajax({
            url: '@Url.Action("AddToCart", "Shop")',
            type: 'POST',
            data: { productId: productId, quantity: 1 },
            success: function(res) {
                if (res.success) {
                    showToast("Đã thêm vào giỏ hàng!");
                    updateCartBadge(res.cartCount);
                }
            },
            error: function(xhr, status, errorThrown) {
                console.error('[AddToCart AJAX Error]', status, errorThrown);
                showToast("Có lỗi xảy ra khi thêm vào giỏ hàng. Vui lòng thử lại.", "error");
            }
        });
    }

    function buyNow() {
        addToCartWithQty();
        setTimeout(function() { window.location.href = '@Url.Action("Cart", "Shop")'; }, 600);
    }

    function showToast(msg, type) {
        var toast = document.createElement('div');
        toast.className = 'toast-notification ' + (type || 'success');
        toast.innerHTML = '<i class="fas ' + (type === 'error' ? 'fa-exclamation-circle' : 'fa-check-circle') + ' me-2"></i>' + msg;
        document.body.appendChild(toast);
        setTimeout(function() { toast.classList.add('show'); }, 10);
        setTimeout(function() { toast.classList.remove('show'); setTimeout(function() { toast.remove(); }, 300); }, 3000);
    }

    function updateCartBadge(count) {
        var badge = document.querySelector('.cart-badge');
        if (badge) {
            badge.textContent = count;
            badge.style.display = count > 0 ? '' : 'none';
        }
    }

    // ==================== TABS ====================
    document.querySelectorAll('.tab-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
            document.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('active'); });
            btn.classList.add('active');
            var tabId = btn.getAttribute('data-tab');
            var pane = document.getElementById(tabId);
            if (pane) pane.classList.add('active');
        });
    });

    // ==================== INIT ====================
    window.addEventListener('DOMContentLoaded', function() {
        // Auto-select first variant if exists
        var firstColor = document.querySelector('.color-btn');
        var firstConfig = document.querySelector('.config-btn');

        if (firstColor && VARIANTS.length > 0) {
            var defaultColor = VARIANTS[0].color;
            if (defaultColor) selectColor(defaultColor);
            else selectedColor = null;
        }
        if (firstConfig && VARIANTS.length > 0) {
            var defaultConfig = VARIANTS[0].config;
            if (defaultConfig) selectConfig(defaultConfig);
            else selectedConfig = null;
        }

        // If no variants, just load default images
        if (VARIANTS.length === 0) {
            updateImages(null);
            updatePrice();
            updateStock();
        }

        initZoomLogic();

        // Keyboard navigation
        document.addEventListener('keydown', function(e) {
            if (e.key === 'ArrowLeft') prevSlide();
            if (e.key === 'ArrowRight') nextSlide();
        });
    });

    // Toast styles (inline, no external CSS needed)
    var style = document.createElement('style');
    style.textContent = `
        .toast-notification {
            position: fixed; bottom: 24px; right: 24px; z-index: 9999;
            background: #333; color: #fff; padding: 14px 20px; border-radius: 10px;
            font-size: 0.9rem; font-weight: 600; box-shadow: 0 8px 24px rgba(0,0,0,0.2);
            display: flex; align-items: center; opacity: 0; transform: translateY(20px);
            transition: all 0.3s ease; pointer-events: none;
        }
        .toast-notification.show { opacity: 1; transform: translateY(0); }
        .toast-notification.success { background: linear-gradient(135deg, #2a9d8f, #21867a); }
        .toast-notification.error { background: linear-gradient(135deg, #e63946, #c92a35); }
    `;
    document.head.appendChild(style);
    </script>
}

<style>
    /* ==================== PAGE HEADER ==================== */
    .page-header-sm {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        padding: 16px 0;
    }
    .breadcrumb-light { background: transparent; padding: 0; margin: 0; font-size: 0.85rem; }
    .breadcrumb-light .breadcrumb-item a { color: rgba(255,255,255,0.7); }
    .breadcrumb-light .breadcrumb-item a:hover { color: white; }
    .breadcrumb-light .breadcrumb-item + .breadcrumb-item::before { color: rgba(255,255,255,0.5); }
    .breadcrumb-light .breadcrumb-item.active { color: white; }

    /* ==================== GALLERY ==================== */
    .product-gallery-container { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 12px; }

    .gallery-main {
        position: relative; width: 100%; aspect-ratio: 1;
        background: #fff; border: 1px solid var(--border); border-radius: var(--radius-lg);
        overflow: hidden; box-shadow: var(--shadow-md);
        display: flex; align-items: center; justify-content: center;
    }

    .main-image-wrapper { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
    .main-image-wrapper img {
        max-width: 100%; max-height: 100%; object-fit: contain;
        transition: opacity 0.2s ease;
    }

    .nav-btn {
        position: absolute; top: 50%; transform: translateY(-50%);
        width: 44px; height: 44px;
        background: rgba(255,255,255,0.85); border: 1px solid var(--border);
        border-radius: 50%; box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        z-index: 10; cursor: pointer; transition: 0.3s;
        display: flex; align-items: center; justify-content: center;
        color: var(--text-primary); backdrop-filter: blur(4px);
    }
    .nav-btn:hover { background: var(--primary); color: white; border-color: var(--primary); box-shadow: 0 6px 20px rgba(0,119,182,0.3); }
