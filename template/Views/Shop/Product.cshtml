    .thumb-item:hover { border-color: #ccc; transform: scale(1.05); }
    .thumb-item.active { border-color: var(--primary); }
    .thumb-item img { width: 100%; height: 100%; object-fit: cover; }

    .gallery-label { font-size: 0.75rem; color: var(--text-muted); text-align: center; }

    .zoom-lens {
        position: absolute; border: 2px solid rgba(0,119,182,0.4);
        background: rgba(255,255,255,0.3); width: 80px; height: 80px;
        display: none; pointer-events: none; z-index: 5;
    }
    .zoom-result {
        position: absolute; top: 0; right: -220px; width: 210px; height: 210px;
        border: 1px solid #ddd; border-radius: 8px; background: white;
        background-repeat: no-repeat; display: none; z-index: 10;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }

    @@media (max-width: 991px) {
        #zoom-result, #zoomLens { display: none !important; }
        .product-gallery-container { position: static; }
    }

    /* ==================== DETAIL CARD ==================== */
    .product-detail-card { background: white; border-radius: var(--radius-lg); padding: 28px; box-shadow: var(--shadow-md); border: 1px solid var(--border); }
    .detail-category { font-size: 0.8rem; font-weight: 700; color: var(--primary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
    .detail-title { font-size: 1.6rem; font-weight: 800; color: var(--text-primary); margin-bottom: 10px; line-height: 1.3; }
    .detail-rating { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
    .stars { color: #F59E0B; font-size: 0.9rem; }
    .rating-text { font-size: 0.85rem; color: var(--text-muted); }

    .detail-price-section { background: linear-gradient(135deg, var(--primary-lightest) 0%, white 100%); border-radius: var(--radius-md); padding: 16px 20px; margin-bottom: 20px; border-left: 4px solid var(--primary); }
    .detail-price { font-size: 2rem; font-weight: 800; color: var(--primary); }
    .detail-price-note { font-size: 0.78rem; color: var(--text-muted); }

    .variant-group { }
    .variant-label { font-weight: 700; font-size: 0.9rem; color: var(--text-primary); margin-bottom: 10px; display: block; }
    .variant-options { }
    .variant-option-btn {
        border-radius: 8px !important; font-weight: 600; font-size: 0.85rem;
        transition: all 0.2s; min-width: 80px;
    }
    .variant-option-btn.active { font-weight: 700; }
    .config-btn.active { background: var(--primary) !important; color: white !important; border-color: var(--primary) !important; }
    .color-btn.active { background: var(--primary) !important; color: white !important; border-color: var(--primary) !important; }

    .selected-variant-summary { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 10px 14px; font-size: 0.85rem; color: #166534; margin-bottom: 16px; }

    .detail-desc { margin-bottom: 20px; }
    .detail-desc h6 { font-weight: 700; margin-bottom: 8px; color: var(--text-primary); }
    .product-description-content p, .product-description-content ul, .product-description-content ol { margin-bottom: 0.75rem; color: var(--text-secondary); line-height: 1.7; }
    .product-description-content ul { padding-left: 1.2rem; }

    .detail-meta { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
    .meta-item { display: flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 600; color: var(--text-secondary); }

    .detail-quantity { display: flex; align-items: center; gap: 14px; margin-bottom: 20px; }
    .qty-label { font-weight: 700; font-size: 0.9rem; color: var(--text-primary); white-space: nowrap; margin: 0; }
    .qty-controls { display: flex; align-items: center; border: 2px solid var(--border); border-radius: var(--radius-md); overflow: hidden; }
    .qty-btn { width: 40px; height: 40px; border: none; background: var(--surface-alt); color: var(--text-secondary); font-size: 0.85rem; cursor: pointer; transition: var(--transition); }
    .qty-btn:hover { background: var(--primary-lightest); color: var(--primary); }
    .qty-input { width: 50px; height: 40px; border: none; text-align: center; font-weight: 700; font-size: 0.95rem; color: var(--text-primary); background: white; }
    .qty-input:focus { outline: none; }
    .stock-note { font-size: 0.78rem; color: var(--text-muted); }

    .detail-actions { display: flex; gap: 12px; margin-bottom: 24px; }
    .btn-add-to-cart { flex: 1; padding: 14px 20px; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; border: none; border-radius: var(--radius-md); font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: var(--transition); }
    .btn-add-to-cart:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,119,182,0.35); }
    .btn-buy-now { flex: 1; padding: 14px 20px; background: white; color: var(--primary); border: 2px solid var(--primary); border-radius: var(--radius-md); font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: var(--transition); }
    .btn-buy-now:hover { background: var(--primary); color: white; transform: translateY(-2px); }

    .detail-features { display: flex; flex-direction: column; gap: 12px; padding-top: 20px; border-top: 1px solid var(--border); }
    .feature-row { display: flex; align-items: center; gap: 12px; }
    .feature-icon-sm { width: 36px; height: 36px; background: var(--primary-lightest); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; font-size: 0.9rem; color: var(--primary); flex-shrink: 0; }
    .feature-row strong { display: block; font-size: 0.88rem; font-weight: 700; }
    .feature-row small { font-size: 0.75rem; color: var(--text-muted); }

    /* ==================== TABS ==================== */
    .product-tabs { background: white; border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); border: 1px solid var(--border); overflow: hidden; }
    .tabs-header { display: flex; border-bottom: 2px solid var(--border); background: var(--surface-alt); }
    .tab-btn { flex: 1; padding: 14px 16px; border: none; background: transparent; font-size: 0.9rem; font-weight: 700; color: var(--text-muted); cursor: pointer; transition: var(--transition); border-bottom: 3px solid transparent; margin-bottom: -2px; }
    .tab-btn:hover { color: var(--primary); background: var(--primary-lightest); }
    .tab-btn.active { color: var(--primary); border-bottom-color: var(--primary); background: white; }
    .tabs-content { padding: 0; }
    .tab-pane { display: none; padding: 24px; }
