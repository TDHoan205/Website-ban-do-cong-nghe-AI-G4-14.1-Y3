@model List<Webstore.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "_ShopLayout";
    var totalAmount = Model.Sum(c => (c.VariantId.HasValue && c.Variant != null ? c.Variant.Price : (c.Product?.Price ?? 0m)) * c.Quantity);
}

<!-- Page Header -->
<div class="page-header">
    <div class="container">
        <h1 class="page-title"><i class="fas fa-shopping-cart me-2"></i>Giỏ hàng của bạn</h1>
        <p class="page-subtitle mb-0">@(Model.Sum(c => c.Quantity)) sản phẩm trong giỏ hàng</p>
    </div>
</div>

<div class="container py-5">
    @Html.AntiForgeryToken()
    @if (Model.Any())
    {
        <div class="row g-4">
            <!-- Cart Items -->
            <div class="col-lg-8">
                <div class="cart-card">
                    <!-- Toolbar -->
                    <div class="cart-toolbar">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="selectAllCart" checked
                                   style="width:20px;height:20px;accent-color:var(--primary);">
                            <label class="form-check-label fw-bold" for="selectAllCart" style="font-size:0.9rem;">Chọn tất
                                cả (<span id="totalItemsCount">@Model.Count</span> sản phẩm)</label>
                            </div>
                            <button type="button" class="btn-clear-cart" onclick="clearSelected()">
                                <i class="fas fa-trash-alt me-1"></i>Xóa đã chọn
                            </button>
                        </div>

                        <!-- Items -->
                        <div class="cart-items">
                            @foreach (var item in Model)
                            {
                                var price = item.VariantId.HasValue && item.Variant != null ? item.Variant.Price : (item.Product?.Price ?? 0m);
                                var lineTotal = (price * item.Quantity).ToString("F2",
                                        System.Globalization.CultureInfo.InvariantCulture);

                                <div class="cart-item" data-product-id="@item.ProductId" data-variant-id="@(item.VariantId ?? 0)"
                                     data-price="@(price.ToString(System.Globalization.CultureInfo.InvariantCulture))"
                                     data-quantity="@item.Quantity">
                                    <div class="cart-item-left">
                                        <input type="checkbox" class="select-for-checkout form-check-input" 
                                               data-product-id="@item.ProductId" data-variant-id="@(item.VariantId ?? 0)"
                                               checked style="accent-color:var(--primary);" />
                                    </div>
                                    <div class="cart-item-img">
                                        @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                        {
                                            <img src="@item.Product.ImageUrl" alt="@(item.Product?.Name)" />
                                        }
                                        else
                                        {
                                            <div class="img-placeholder">
                                                <i class="fas fa-box" style="font-size:1.5rem;"></i>
                                            </div>
                                        }
                                    </div>
                                    <div class="cart-item-info">
                                        <h5 class="cart-item-name">@(item.Product?.Name)</h5>
                                        @if (item.VariantId.HasValue && item.Variant != null)
                                        {
                                            <div class="cart-item-variant text-primary fw-bold" style="font-size: 0.85rem;">
                                                <i class="fas fa-cog me-1"></i>
                                                @(item.Variant.Color) @(!string.IsNullOrEmpty(item.Variant.Storage) ? " / " + item.Variant.Storage : "")
                                            </div>
                                        }
                                        <div class="cart-item-cat">@item.Product?.Category?.Name</div>
                                        <div class="cart-item-price">@(price.ToString("N0")) ₫</div>
                                    </div>
                                    <div class="cart-item-qty">
                                        <div class="qty-controls">
                                            <button type="button" class="qty-btn" onclick="changeQuantity(@item.ProductId, @(item.VariantId ?? 0), -1)">
                                                <i class="fas fa-minus"></i>
                                            </button>
                                            <input type="number" class="qty-input" value="@item.Quantity" readonly
                                                   id="qty-@item.ProductId-@(item.VariantId ?? 0)">
                                            <button type="button" class="qty-btn" onclick="changeQuantity(@item.ProductId, @(item.VariantId ?? 0), 1)">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="cart-item-total">
                                        <span class="line-total">@((price * item.Quantity).ToString("N0"))
                                            ₫</span>
                                        </div>
                                        <div class="cart-item-actions">
                                            <button class="btn-remove-item" onclick="removeCartItem(@item.ProductId, @(item.VariantId ?? 0))"
                                                    title="Xóa sản phẩm">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Continue Shopping -->
                        <div class="mt-3">
                            <a asp-controller="Shop" asp-action="Products" class="btn btn-back-shop">
                                <i class="fas fa-arrow-left me-2"></i>Tiếp tục mua hàng
                            </a>
                        </div>
                    </div>

                    <!-- Order Summary -->
                    <div class="col-lg-4">
                        <div class="summary-card">
                            <div class="summary-header">
                                <h5><i class="fas fa-receipt me-2"></i>Tóm tắt đơn hàng</h5>
                            </div>
                            <div class="summary-body">
                                <div class="summary-row">
                                    <span>Số sản phẩm</span>
                                    <span class="fw-bold" id="selectedCount">0</span>
                                </div>
                                <div class="summary-row">
                                    <span>Tạm tính</span>
                                    <span id="selectedAmount">0 ₫</span>
                                </div>
                                <div class="summary-row">
                                    <span>Phí vận chuyển</span>
                                    <span class="text-success fw-bold">Miễn phí</span>
                                </div>
                                <div class="summary-divider"></div>
                                <div class="summary-row summary-total">
                                    <span>Tổng cộng</span>
                                    <span class="total-price" id="totalPrice">0 ₫</span>
                                </div>

                                <button type="button" class="btn btn-checkout" id="checkoutSelectedBtn" onclick="goCheckout()">
                                    <i class="fas fa-credit-card me-2"></i>Thanh toán ngay
                                </button>

                                <div class="summary-security">
                                    <i class="fas fa-shield-alt"></i>
                                    <span>Thanh toán an toàn, bảo mật</span>
                                </div>
                            </div>
                        </div>

                        <!-- Features -->
                        <div class="summary-features mt-3">
                            <div class="sf-item">
                                <i class="fas fa-truck"></i>
                                <span>Miễn phí vận chuyển đơn từ 500K</span>
                            </div>
                            <div class="sf-item">
                                <i class="fas fa-undo"></i>
                                <span>Đổi trả trong 7 ngày</span>
                            </div>
                            <div class="sf-item">
                                <i class="fas fa-shield-alt"></i>
                                <span>Bảo hành chính hãng</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
    else
            {
                <!-- Empty Cart -->
                <div class="empty-cart-state">
                    <div class="empty-cart-icon">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <h3>Giỏ hàng trống</h3>
                    <p>Bạn chưa có sản phẩm nào trong giỏ hàng. Hãy bắt đầu mua hàng ngay!</p>
                    <a asp-controller="Shop" asp-action="Products" class="btn btn-hero-primary">
                        <i class="fas fa-shopping-bag me-2"></i>Mua hàng ngay
                    </a>
                </div>
            }
        </div>

        <style>
            /* Cart Card */
            .cart-card {
                background: white;
                border-radius: var(--radius-lg);
                box-shadow: var(--shadow-sm);
                overflow: hidden;
                border: 1px solid var(--border);
            }

            .cart-toolbar {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 14px 20px;
                background: var(--surface-alt);
                border-bottom: 1px solid var(--border);
            }

            .btn-clear-cart {
                background: none;
                border: none;
                color: var(--danger);
                font-size: 0.85rem;
                font-weight: 600;
                cursor: pointer;
                padding: 6px 12px;
                border-radius: var(--radius-sm);
                transition: var(--transition);
            }

            .btn-clear-cart:hover {
                background: rgba(239, 68, 68, 0.1);
            }

            /* Cart Items */
            .cart-item {
                display: grid;
                grid-template-columns: 40px 90px 1fr auto auto auto;
                align-items: center;
                gap: 16px;
                padding: 16px 20px;
                border-bottom: 1px solid var(--border);
                transition: var(--transition);
            }

            .cart-item:hover {
                background: var(--surface-alt);
            }

            .cart-item:last-child {
                border-bottom: none;
            }

            .cart-item-img {
                width: 90px;
                height: 90px;
                background: var(--surface-alt);
                border-radius: var(--radius-md);
                overflow: hidden;
                display: flex;
                align-items: center;
                justify-content: center;
                border: 1px solid var(--border);
                flex-shrink: 0;
            }

            .cart-item-img img {
                width: 100%;
                height: 100%;
                object-fit: contain;
            }

            .img-placeholder {
                width: 100%;
                height: 100%;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .cart-item-info {
                min-width: 0;
            }

            .cart-item-name {
                font-size: 0.95rem;
                font-weight: 700;
                color: var(--text-primary);
                margin-bottom: 4px;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

            .cart-item-cat {
                font-size: 0.75rem;
                color: var(--text-muted);
                margin-bottom: 6px;
            }

            .cart-item-price {
                font-size: 0.95rem;
                font-weight: 700;
                color: var(--primary);
            }

            .cart-item-qty .qty-controls {
                display: flex;
                align-items: center;
                border: 2px solid var(--border);
                border-radius: var(--radius-md);
                overflow: hidden;
                background: white;
            }

            .qty-controls .qty-btn {
                width: 34px;
                height: 36px;
                border: none;
                background: var(--surface-alt);
                color: var(--text-secondary);
                font-size: 0.75rem;
                cursor: pointer;
                transition: var(--transition);
            }

            .qty-controls .qty-btn:hover {
                background: var(--primary-lightest);
                color: var(--primary);
            }

            .qty-controls .qty-input {
                width: 42px;
                height: 36px;
                border: none;
                text-align: center;
                font-weight: 700;
                font-size: 0.88rem;
                color: var(--text-primary);
                background: white;
            }

            .qty-controls .qty-input:focus {
                outline: none;
            }

            .cart-item-total .line-total {
                font-size: 1rem;
                font-weight: 800;
                color: var(--text-primary);
                white-space: nowrap;
            }

            .cart-item-actions {}

            .btn-remove-item {
                width: 36px;
                height: 36px;
                border: 2px solid var(--border);
                border-radius: var(--radius-sm);
                background: white;
                color: var(--text-muted);
                cursor: pointer;
                transition: var(--transition);
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .btn-remove-item:hover {
                border-color: var(--danger);
                background: rgba(239, 68, 68, 0.1);
                color: var(--danger);
            }

            .btn-back-shop {
                display: inline-flex;
                align-items: center;
                padding: 10px 20px;
                border: 2px solid var(--primary);
                color: var(--primary);
                border-radius: var(--radius-md);
                font-weight: 700;
                font-size: 0.88rem;
                background: white;
                transition: var(--transition);
            }

            .btn-back-shop:hover {
                background: var(--primary);
                color: white;
                transform: translateX(-3px);
            }

            /* Summary Card */
            .summary-card {
                background: white;
                border-radius: var(--radius-lg);
                box-shadow: var(--shadow-md);
                overflow: hidden;
                border: 1px solid var(--border);
                position: sticky;
                top: 80px;
            }

            .summary-header {
                padding: 16px 20px;
                background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
                color: white;
            }

            .summary-header h5 {
                margin: 0;
                font-weight: 800;
                font-size: 1rem;
            }

            .summary-body {
                padding: 20px;
            }

            .summary-row {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 12px;
                font-size: 0.9rem;
                color: var(--text-secondary);
            }

            .summary-divider {
                border-top: 2px dashed var(--border);
                margin: 12px 0;
            }

            .summary-total {
                font-size: 1.05rem;
            }

            .summary-total span:first-child {
                font-weight: 800;
                color: var(--text-primary);
            }

            .total-price {
                font-size: 1.4rem !important;
                font-weight: 800 !important;
                color: var(--primary) !important;
            }

            .btn-checkout {
                width: 100%;
                padding: 14px;
                background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
                color: white;
                border: none;
                border-radius: var(--radius-md);
                font-weight: 800;
                font-size: 0.95rem;
                cursor: pointer;
                transition: var(--transition);
                margin-top: 4px;
            }

            .btn-checkout:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(0, 119, 182, 0.35);
            }

            .btn-checkout:disabled {
                background: #ccc;
                cursor: not-allowed;
                transform: none;
                box-shadow: none;
            }

            .summary-security {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 6px;
                margin-top: 12px;
                color: var(--text-muted);
                font-size: 0.78rem;
            }

            .summary-security i {
                color: var(--success);
            }

            .summary-features {
                background: white;
                border-radius: var(--radius-lg);
                padding: 16px;
                box-shadow: var(--shadow-sm);
                border: 1px solid var(--border);
            }

            .sf-item {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 10px;
                font-size: 0.82rem;
                color: var(--text-secondary);
                font-weight: 600;
            }

            .sf-item:last-child {
                margin-bottom: 0;
            }

            .sf-item i {
                color: var(--primary);
                font-size: 0.9rem;
                width: 18px;
            }

            /* Empty Cart */
            .empty-cart-state {
                text-align: center;
                padding: 80px 20px;
            }

            .empty-cart-icon {
                width: 120px;
                height: 120px;
                background: linear-gradient(135deg, var(--primary-lightest), white);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 3rem;
                color: var(--primary);
                margin: 0 auto 24px;
                border: 3px dashed var(--primary-lighter);
            }

            .empty-cart-state h3 {
                font-weight: 800;
                margin-bottom: 10px;
            }

            .empty-cart-state p {
                color: var(--text-muted);
                margin-bottom: 24px;
            }

            .btn-hero-primary {
                background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
                color: white;
                padding: 14px 28px;
                border-radius: 50px;
                font-weight: 700;
                border: none;
                display: inline-flex;
                align-items: center;
                transition: var(--transition);
            }

            .btn-hero-primary:hover {
                transform: translateY(-2px);
                box-shadow: var(--shadow-md);
                color: white;
            }

            /* Responsive */
            @@media (max-width: 991px) {
                .cart-item {
                    grid-template-columns: 40px 70px 1fr auto auto;
                    gap: 10px;
                }

                .cart-item-img {
                    width: 70px;
                    height: 70px;
                }

                .cart-item-total {
                    display: none;
                }

                .summary-card {
                    position: static;
                }
            }

            @@media (max-width: 575px) {
                .cart-item {
                    grid-template-columns: 1fr auto auto;
                }

                .cart-item-left {
                    display: none;
                }

                .cart-item-img {
                    width: 60px;
                    height: 60px;
                }
            }
        </style>

        <script>
            // =====================================================
            // Get CSRF Token from hidden input
            // =====================================================
            function getAntiForgeryToken() {
                var tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                return tokenElement ? tokenElement.value : '';
            }

            // =====================================================
            // Thay đổi số lượng (đọc qty hiện tại từ data-attribute)
            // =====================================================
            // Fix: Chỉ gửi variantId khi > 0, KHÔNG gửi variantId=0
            function changeQuantity(productId, variantId, delta) {
                var selector = '.cart-item[data-product-id="' + productId + '"]';
                if (variantId > 0) {
                    selector += '[data-variant-id="' + variantId + '"]';
                }
                var item = document.querySelector(selector);
                if (!item) return;
                var currentQty = parseInt(item.dataset.quantity) || 0;
                var newQty = currentQty + delta;
                if (newQty <= 0) {
                    removeCartItem(productId, variantId);
                    return;
                }
                // Cập nhật UI ngay lập tức
                item.dataset.quantity = newQty;
                var price = parseFloat(item.dataset.price) || 0;
                var qtyInput = item.querySelector('.qty-input');
                var lineTotalEl = item.querySelector('.line-total');
                if (qtyInput) qtyInput.value = newQty;
                if (lineTotalEl) lineTotalEl.textContent = formatCurrency(price * newQty);
                updateCartSummary();

                // Gửi lên server - chỉ gửi variantId khi > 0
                var token = getAntiForgeryToken();
                var body = 'productId=' + productId + '&quantity=' + newQty;
                if (variantId > 0) body += '&variantId=' + variantId;

                fetch('@Url.Action("UpdateCart", "Shop")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-CSRF-TOKEN': token
                    },
                    body: body
                }).then(function (res) { return res.json(); })
                    .then(function (data) {
                        if (!data) return;
                        if (data.redirectUrl) {
                            window.location.href = data.redirectUrl;
                            return;
                        }
                        if (data.success === false && data.message) {
                            if (window.showToast) window.showToast('warning', data.message);
                            else alert(data.message);
                        }
                        if (data.newQuantity !== undefined && data.newQuantity !== null) {
                            var correctedQty = parseInt(data.newQuantity);
                            item.dataset.quantity = correctedQty;
                            if (qtyInput) qtyInput.value = correctedQty;
                            if (lineTotalEl) lineTotalEl.textContent = formatCurrency(price * correctedQty);
                            updateCartSummary();
                        }
                    }).catch(function (err) {
                        console.error('UpdateCart error:', err);
                    });
            }

            // =====================================================
            // Xóa sản phẩm khỏi giỏ hàng
            // =====================================================
            // Fix: Chỉ gửi variantId khi > 0, KHÔNG gửi variantId=0
            function removeCartItem(productId, variantId) {
                if (!confirm('Xóa sản phẩm này khỏi giỏ hàng?')) return;
                var token = getAntiForgeryToken();
                var body = 'productId=' + productId;
                if (variantId > 0) body += '&variantId=' + variantId;

                fetch('@Url.Action("RemoveFromCart", "Shop")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-CSRF-TOKEN': token
                    },
                    body: body
                }).then(function (res) { return res.json(); })
                    .then(function (data) {
                        if (data && data.redirectUrl) { window.location.href = data.redirectUrl; }
                        else {
                            // Xóa row khỏi DOM và cập nhật tóm tắt ngay lập tức
                            var selector = '.cart-item[data-product-id="' + productId + '"]';
                            if (variantId > 0) selector += '[data-variant-id="' + variantId + '"]';
                            var item = document.querySelector(selector);
                            if (item) item.remove();
                            // Cập nhật số sản phẩm hiển thị
                            var countEl = document.getElementById('totalItemsCount');
                            if (countEl) {
                                var currentCount = parseInt(countEl.textContent) || 0;
                                countEl.textContent = Math.max(0, currentCount - 1);
                            }
                            // Nếu không còn sản phẩm nào, reload trang
                            if (!document.querySelector('.cart-item')) {
                                window.location.reload();
                            } else {
                                updateCartSummary();
                            }
                        }
                    }).catch(function () { window.location.reload(); });
            }

            // =====================================================
            // Xóa nhiều sản phẩm đã chọn
            // =====================================================
            // Fix: Chỉ gửi variantId khi > 0
            function clearSelected() {
                var checked = document.querySelectorAll('.select-for-checkout:checked');
                if (checked.length === 0) {
                    if (window.showToast) window.showToast('warning', 'Vui lòng chọn sản phẩm để xóa.');
                    else alert('Vui lòng chọn sản phẩm để xóa.');
                    return;
                }
                if (!confirm('Xóa ' + checked.length + ' sản phẩm đã chọn?')) return;
                var promises = [];
                var token = getAntiForgeryToken();
                checked.forEach(function (cb) {
                    var pId = cb.getAttribute('data-product-id');
                    var vId = cb.getAttribute('data-variant-id');
                    var body = 'productId=' + pId;
                    if (vId && parseInt(vId) > 0) body += '&variantId=' + vId;
                    promises.push(fetch('@Url.Action("RemoveFromCart", "Shop")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'X-CSRF-TOKEN': token
                        },
                        body: body
                    }));
                });
                Promise.all(promises).then(function () { window.location.reload(); });
            }

            // =====================================================
            // Thanh toán: chỉ gửi sản phẩm đã chọn
            // =====================================================
            function goCheckout() {
                var selectedItems = Array.from(document.querySelectorAll('.select-for-checkout:checked'))
                    .map(function (cb) { 
                        return { 
                            p: cb.getAttribute('data-product-id'), 
                            v: cb.getAttribute('data-variant-id') 
                        }; 
                    });

                if (selectedItems.length === 0) {
                    if (window.showToast) {
                        window.showToast('warning', 'Vui lòng chọn ít nhất một sản phẩm để thanh toán.');
                    } else {
                        alert('Vui lòng chọn ít nhất một sản phẩm để thanh toán.');
                    }
                    return;
                }

                // Encode as JSON or simpler format for query string
                var selectedParam = selectedItems.map(i => i.p + '-' + i.v).join(',');
                window.location.href = '@Url.Action("Checkout", "Shop")?selected=' + selectedParam;
            }

            // =====================================================
            // Tóm tắt đơn hàng: CHỈ tính sản phẩm được tick chọn
            // =====================================================
            function updateCartSummary() {
                var checkedBoxes = document.querySelectorAll('.select-for-checkout:checked');
                var totalQty = 0;
                var totalAmount = 0;

                checkedBoxes.forEach(function (cb) {
                    var item = cb.closest('.cart-item');
                    if (item) {
                        var price = parseFloat(item.dataset.price) || 0;
                        var qty = parseInt(item.dataset.quantity) || 0;
                        totalQty += qty;
                        totalAmount += price * qty;
                    }
                });

                var qtyEl = document.getElementById('selectedCount');
                var amountEl = document.getElementById('selectedAmount');
                var totalEl = document.getElementById('totalPrice');
                if (qtyEl) qtyEl.textContent = totalQty;
                if (amountEl) amountEl.textContent = formatCurrency(totalAmount);
                if (totalEl) totalEl.textContent = formatCurrency(totalAmount);
            }

            // =====================================================
            // Format tiền tệ VND
            // =====================================================
            function formatCurrency(amount) {
                return amount.toLocaleString('vi-VN') + ' ₫';
            }

            // =====================================================
            // Khởi tạo khi trang load
            // =====================================================
            document.addEventListener('DOMContentLoaded', function () {
                // Tính tóm tắt lần đầu
                updateCartSummary();

                var selectAll = document.getElementById('selectAllCart');
                var checkboxes = document.querySelectorAll('.cart-items .select-for-checkout');

                // Chọn tất cả / bỏ chọn tất cả
                if (selectAll) {
                    selectAll.addEventListener('change', function () {
                        checkboxes.forEach(function (cb) { cb.checked = selectAll.checked; });
                        updateCartSummary();
                    });
                }

                // Khi tick/bỏ tick từng sản phẩm => cập nhật tóm tắt
                checkboxes.forEach(function (cb) {
                    cb.addEventListener('change', function () {
                        if (selectAll) {
                            var allChecked = Array.from(checkboxes).every(function (c) { return c.checked; });
                            selectAll.checked = allChecked;
                        }
                        updateCartSummary();
                    });
                });
            });
        </script>
