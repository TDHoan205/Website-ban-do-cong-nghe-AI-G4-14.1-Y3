@{
    ViewData["Title"] = "Trang chủ";
    Layout = "_ShopLayout";
}

<!-- Hero Banner -->
<section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-particles"></div>
    <div class="container position-relative">
        <div class="row align-items-center min-vh-80">
            <div class="col-lg-6">
                <div class="hero-badge-modern">
                    <span class="badge-icon"><i class="fas fa-robot"></i></span>
                    <span>AI Assistant powered</span>
                </div>
                <h1 class="hero-title-modern">
                    Khám phá
                    <span class="text-gradient-hero">Công nghệ</span>
                    <br />Thông minh hơn
                </h1>
                <p class="hero-desc-modern">
                    Hệ thống AI tư vấn thông minh giúp bạn tìm kiếm sản phẩm hoàn hảo. 
                    Cam kết chính hãng với bảo hành đáng tin cậy.
                </p>
                <div class="hero-actions-modern">
                    <a asp-controller="Shop" asp-action="Products" class="btn-hero-primary-modern">
                        <i class="fas fa-shopping-bag me-2"></i>
                        <span>Mua sắm ngay</span>
                    </a>
                    <a href="#featured-products" class="btn-hero-secondary-modern">
                        <i class="fas fa-play-circle me-2"></i>
                        <span>Xem sản phẩm</span>
                    </a>
                </div>
                <div class="hero-stats-modern">
                    <div class="stat-item-modern">
                        <span class="stat-number-modern">500+</span>
                        <span class="stat-label-modern">Sản phẩm</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item-modern">
                        <span class="stat-number-modern">10K+</span>
                        <span class="stat-label-modern">Khách hàng</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item-modern">
                        <span class="stat-number-modern">4.9</span>
                        <span class="stat-label-modern">Đánh giá</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <div class="hero-visual-wrapper">
                    <div class="hero-main-visual">
                        <div class="main-product-display">
                            <div class="product-glow"></div>
                            <div class="product-circle-bg"></div>
                            <div class="featured-product-card-modern">
                                <img src="/images/products/iPhone_15_Pro_Max.png" alt="iPhone 15 Pro Max" class="featured-product-img" />
                                <div class="featured-product-overlay">
                                    <span class="featured-badge-float">Mới</span>
                                    <div class="featured-info-float">
                                        <span class="featured-name-float">iPhone 15 Pro Max</span>
                                        <span class="featured-price-float">34.990.000đ</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="floating-items">
                            <div class="float-icon fi-1"><i class="fas fa-mobile-alt"></i></div>
                            <div class="float-icon fi-2"><i class="fas fa-laptop"></i></div>
                            <div class="float-icon fi-3"><i class="fas fa-headphones-alt"></i></div>
                            <div class="float-icon fi-4"><i class="fas fa-tablet-alt"></i></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="hero-wave">
        <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="#eef3f8"/>
        </svg>
    </div>
</section>

<!-- Trust Badges -->
<section class="trust-section">
    <div class="container">
        <div class="trust-badges-wrapper">
            <div class="trust-badge-item">
                <div class="trust-badge-icon"><i class="fas fa-shield-alt"></i></div>
                <div class="trust-badge-content">
                    <span class="trust-badge-title">Chính hãng 100%</span>
                    <span class="trust-badge-desc">Cam kết authentic</span>
                </div>
            </div>
            <div class="trust-badge-item">
                <div class="trust-badge-icon"><i class="fas fa-truck"></i></div>
                <div class="trust-badge-content">
                    <span class="trust-badge-title">Giao hàng nhanh</span>
                    <span class="trust-badge-desc">Miễn phí từ 500K</span>
                </div>
            </div>
            <div class="trust-badge-item">
                <div class="trust-badge-icon"><i class="fas fa-undo-alt"></i></div>
                <div class="trust-badge-content">
                    <span class="trust-badge-title">Đổi trả 7 ngày</span>
                    <span class="trust-badge-desc">Không phí phát sinh</span>
                </div>
            </div>
            <div class="trust-badge-item">
                <div class="trust-badge-icon"><i class="fas fa-headset"></i></div>
                <div class="trust-badge-content">
                    <span class="trust-badge-title">Hỗ trợ 24/7</span>
                    <span class="trust-badge-desc">Luôn sẵn sàng</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories -->
<section class="py-5" id="categories">
    <div class="container">
        <div class="section-header-modern">
            <div class="section-title-group">
                <span class="section-label">Khám phá</span>
                <h2 class="section-title-modern">
                    <i class="fas fa-th-large section-title-icon"></i>
                    Danh mục sản phẩm
                </h2>
                <p class="section-subtitle-modern">Tìm kiếm sản phẩm theo nhu cầu của bạn</p>
            </div>
            <a asp-controller="Shop" asp-action="Products" class="btn-view-all">
                Xem tất cả <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>
        <div class="categories-grid">
            @foreach (var category in ((List<Webstore.Models.Category>)ViewBag.Categories).Take(8))
            {
                <a asp-controller="Shop" asp-action="Products" asp-route-categoryId="@category.CategoryId"
                   class="category-card-modern">
                    <div class="category-icon-wrap">
                        <i class="fas fa-@GetCategoryIcon(category.Name)"></i>
                    </div>
                    <span class="category-name-modern">@category.Name</span>
                    <div class="category-card-shimmer"></div>
                </a>
            }
        </div>
    </div>
</section>

<!-- Featured Products - New Arrivals -->
@{
    var newProducts = (ViewBag.NewProducts as List<Webstore.Models.Product>) ?? new List<Webstore.Models.Product>();
    var newProductsPage = (int)(ViewBag.NewProductsPage ?? 1);
    var newProductsTotalPages = (int)Math.Ceiling(newProducts.Count / 4.0);
    var displayNewProducts = newProducts.Skip((newProductsPage - 1) * 4).Take(4).ToList();
}
<section class="py-5 section-featured" id="sanpham-moi">
    <div class="container">
        <div class="section-header-modern">
            <div class="section-title-group">
                <span class="section-label section-label-new">Mới nhất</span>
                <h2 class="section-title-modern">
                    <i class="fas fa-bolt section-title-icon text-warning"></i>
                    Sản phẩm mới về
                </h2>
                <p class="section-subtitle-modern">Cập nhật xu hướng công nghệ mới nhất</p>
            </div>
            <a asp-controller="Shop" asp-action="Products" asp-route-filter="new" class="btn-view-all">
                Xem tất cả <i class="fas fa-arrow-right ms-1"></i>
            </a>
        </div>

        <div id="new-products-container">
            @await Html.PartialAsync("_NewArrivalsPartial", displayNewProducts)
        </div>
    </div>
</section>

<!-- Special Offers Banner -->
@if (ViewBag.DealProducts != null && ((List<Webstore.Models.Product>)ViewBag.DealProducts).Any())
{
    var dealProducts = (List<Webstore.Models.Product>)ViewBag.DealProducts;
    <section class="py-5 section-deals-modern">
        <div class="container">
            <div class="deals-banner">
                <div class="deals-banner-content">
                    <span class="deals-label"><i class="fas fa-fire me-2"></i>Flash Sale</span>
                    <h2 class="deals-title">Giảm giá cực sốc</h2>
                    <p class="deals-desc">Ưu đãi có hạn - Nhanh tay chớp ngay!</p>
                    <a asp-controller="Shop" asp-action="Products" class="btn-deals">
                        Mua ngay <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
                <div class="deals-banner-products">
                    @foreach (var product in dealProducts.Take(3))
                    {
                        <div class="deal-mini-card">
                            <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/products/placeholder.svg" : product.ImageUrl)" 
                                 alt="@product.Name" class="deal-mini-img" />
                            <div class="deal-mini-info">
                                <span class="deal-mini-name">@product.Name</span>
                                <span class="deal-mini-price">@product.Price.ToString("N0")đ</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
}

<!-- Hot Products -->
@{
    var hotProducts = (ViewBag.HotProducts as List<Webstore.Models.Product>) ?? new List<Webstore.Models.Product>();
    var hotProductsPage = (int)(ViewBag.HotProductsPage ?? 1);
    var hotProductsTotalPages = (int)Math.Ceiling(hotProducts.Count / 4.0);
    var displayHotProducts = hotProducts.Skip((hotProductsPage - 1) * 4).Take(4).ToList();
}
@if (hotProducts.Any())
{
    <section class="py-5 section-hot" id="sanpham-hot">
        <div class="container">
            <div class="section-header-modern">
                <div class="section-title-group">
                    <span class="section-label section-label-hot">Xu hướng</span>
                    <h2 class="section-title-modern">
                        <i class="fas fa-fire section-title-icon text-danger"></i>
                        Sản phẩm hot
