@section Styles {
    <link rel="stylesheet" href="~/css/homepage.css" />
    <style>
        /* CSS DÙNG CHUNG CHO PRODUCT CARDS */
        .product-card {
            border: 1px solid #f0f0f0;
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.3s ease;
            background: #fff;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08);
            border-color: var(--primary);
        }
        .product-card-img {
            position: relative;
            aspect-ratio: 1/1;
            overflow: hidden;
            background: #f8f9fa;
            display: block;
        }
        .product-card-img img {
            width: 100%; height: 100%; object-fit: cover;
            transition: transform 0.5s ease;
        }
        .product-card:hover .product-card-img img { transform: scale(1.08); }

        .product-badges {
            position: absolute; top: 12px; left: 12px; z-index: 10;
            display: flex; flex-direction: column; gap: 6px;
        }
        .badge-hot, .badge-new {
            padding: 4px 14px; font-size: 11px; font-weight: 700;
            color: #fff; border-radius: 50px; display: flex;
            align-items: center; gap: 5px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            text-transform: uppercase;
        }
        .badge-hot { background: #ff4d4d; }
        .badge-hot::before { content: '🔥'; }
        .badge-new { background: #3498db; }
        .badge-new::before { content: '⚡'; }

        .product-card-body { padding: 15px; display: flex; flex-direction: column; flex-grow: 1; }
        .product-card-cat { font-size: 11px; color: #888; text-transform: uppercase; margin-bottom: 5px; }
        .product-card-title {
            font-size: 15px; font-weight: 600; color: #333; margin-bottom: 8px;
            line-height: 1.4; height: 42px; overflow: hidden;
            display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        }
        .product-card-title a { color: inherit; text-decoration: none; }
        .product-card-rating { color: #ff9f43; font-size: 12px; margin-bottom: 10px; display: flex; align-items: center; gap: 4px; }
        .product-card-price { font-size: 18px; font-weight: 700; color: #ee4d2d; margin-top: auto; margin-bottom: 15px; }
        
        .btn-add-cart {
            width: 100%; padding: 10px; background: var(--primary);
            color: #fff; border: none; border-radius: 8px; font-weight: 600;
            display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.3s;
        }
        .btn-add-cart:hover { background: #005f91; }

        /* Pagination Styles */
        .pagination-wrapper-simple { display: flex; justify-content: center; margin: 30px 0; }
        .pagination-container-styled { display: flex; align-items: center; gap: 15px; }
        .btn-nav-round {
            width: 40px; height: 40px; border: 1px solid #eee; background: #fff;
            color: #555; border-radius: 50%; display: flex; align-items: center;
            justify-content: center; cursor: pointer; transition: 0.3s;
        }
        .btn-nav-round:hover:not(.disabled) { border-color: var(--primary); color: var(--primary); }
        .btn-nav-round.disabled { opacity: 0.4; cursor: not-allowed; }
        .page-number-active {
            width: 40px; height: 40px; background: var(--primary); color: #fff;
            border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700;
        }

        /* FIX HERO BANNER CONFLICTS */
        .featured-product-card-modern {
            position: relative; background: #fff; border-radius: 20px;
            padding: 30px; box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            max-width: 400px; margin: 0 auto;
        }
        .featured-product-img { width: 100%; height: auto; object-fit: contain; }
        .featured-product-overlay {
            position: absolute; bottom: 20px; left: 20px; right: 20px;
            background: rgba(255,255,255,0.9); backdrop-filter: blur(10px);
            padding: 15px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.05);
        }
        .featured-badge-float {
            background: var(--primary); color: #fff; padding: 4px 12px;
            border-radius: 50px; font-size: 10px; font-weight: 700;
            text-transform: uppercase; margin-bottom: 8px; display: inline-block;
        }
        .featured-info-float { display: flex; justify-content: space-between; align-items: center; }
        .featured-name-float { font-weight: 600; color: #333; }
        .featured-price-float { color: #ee4d2d; font-weight: 700; }
    </style>
}

@section Scripts {
    <script>
        function loadNewProducts(page) {
            const container = $('#new-products-container');
            container.css('opacity', '0.5');
            
            $.get('@Url.Action("GetFeaturedProductsPartial", "Shop")', { page: page }, function(data) {
                container.html(data);
                container.css('opacity', '1');
                
                // Scroll to section head smoothly
                document.getElementById('sanpham-moi').scrollIntoView({ behavior: 'smooth', block: 'start' });
                
                // Re-init any animations if needed
                if (typeof initStaggerCards === 'function') initStaggerCards();
            });
        }

        function loadHotProducts(page) {
            const container = $('#hot-products-container');
            container.css('opacity', '0.5');
            
            $.get('@Url.Action("GetHotProductsPartial", "Shop")', { page: page }, function(data) {
                container.html(data);
                container.css('opacity', '1');
                
                // Scroll to section head smoothly
                document.getElementById('sanpham-hot').scrollIntoView({ behavior: 'smooth', block: 'start' });
                
                // Re-init any animations if needed
                if (typeof initStaggerCards === 'function') initStaggerCards();
            });
        }
    </script>
}

@functions {
    public string GetCategoryIcon(string name)
    {
        if (string.IsNullOrEmpty(name)) return "cube";
        name = name.ToLower();
         if (name.Contains("điện thoại") || name.Contains("dien thoai") || name.Contains("phone") || name.Contains("iphone") || name.Contains("samsung") || name.Contains("xiaomi"))
             return "mobile-alt";
         if (name.Contains("laptop") || name.Contains("máy tính") || name.Contains("may tinh") || name.Contains("macbook") || name.Contains("dell") || name.Contains("hp"))
             return "laptop";
         if (name.Contains("tablet") || name.Contains("ipad"))
             return "tablet-alt";
         if (name.Contains("âm thanh") || name.Contains("am thanh") || name.Contains("tai nghe") || name.Contains("tái nghe") || name.Contains("headphone") || name.Contains("airpod"))
             return "headphones-alt";
         if (name.Contains("đồng hồ") || name.Contains("dong ho") || name.Contains("watch") || name.Contains("smartwatch"))
             return "clock";
         if (name.Contains("phụ kiện") || name.Contains("phu kien") || name.Contains("accessory") || name.Contains("sạc") || name.Contains("sac") || name.Contains("cable"))
             return "plug";
         if (name.Contains("camera") || name.Contains("webcam"))
             return "camera";
         if (name.Contains("game") || name.Contains("console"))
             return "gamepad";
         if (name.Contains("bàn phím") || name.Contains("ban phim") || name.Contains("keyboard"))
             return "keyboard";
         if (name.Contains("chuột") || name.Contains("chuot") || name.Contains("mouse"))
            return "mouse";
        return "cube";
    }
}
