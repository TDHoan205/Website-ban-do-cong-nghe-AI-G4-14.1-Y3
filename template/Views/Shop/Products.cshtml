@using Webstore.Services
@model PagedList<Webstore.Models.Product>
@{
    var filters = ViewBag.Filters as ProductFiltersViewModel;
    ViewData["Title"] = "Sản phẩm";
    Layout = "_ShopLayout";
}

<div class="shop-products-page">
<!-- Page Header -->
<div class="page-header products-page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center products-header-inner">
            <div>
                <h1 class="page-title"><i class="fas fa-th-large me-2"></i>Tất cả sản phẩm</h1>
                <p class="page-subtitle mb-0">Hiển thị @Model.TotalCount sản phẩm</p>
            </div>
        </div>
    </div>
</div>

<div class="container py-4 products-page-content">
    <div class="row">
        <!-- Sidebar Filter -->
        <div class="col-lg-3 mb-4">
            <div class="filter-card">
                <div class="filter-header">
                    <h5><i class="fas fa-filter me-2"></i>Bộ lọc nâng cao</h5>
                </div>
                <div class="filter-body">
                    <form method="get" asp-controller="Shop" asp-action="Products">
                        <input type="hidden" name="filter" value="@ViewBag.Filter" />
                        <!-- Search -->
                        <div class="filter-group">
                            <label class="filter-label">Tìm kiếm</label>
                            <div class="position-relative">
                                <input type="text" name="search" class="filter-input" value="@ViewBag.Search"
                                       placeholder="Tên sản phẩm...">
                                <i class="fas fa-search position-absolute end-0 top-50 translate-middle-y me-3 text-muted"></i>
                            </div>
                        </div>

                        <!-- Category Filter -->
                        <div class="filter-group">
                            <label class="filter-label">Danh mục</label>
                            <select name="categoryId" class="filter-select">
                                <option value="">Tất cả danh mục</option>
                                @foreach (var category in ViewBag.Categories)
                                {
                                    <option value="@category.CategoryId"
                                            selected="@(ViewBag.CategoryId?.ToString() == category.CategoryId.ToString())">
                                        @category.Name
                                    </option>
                                }
                            </select>
                        </div>

                        <!-- Price Range -->
                        <div class="filter-group">
                            <label class="filter-label">Khoảng giá (₫)</label>
                            <div class="d-flex gap-2 align-items-center">
                                <input type="number" name="minPrice" class="filter-input py-1" value="@ViewBag.MinPrice" placeholder="Từ">
                                <span>-</span>
                                <input type="number" name="maxPrice" class="filter-input py-1" value="@ViewBag.MaxPrice" placeholder="Đến">
                            </div>
                        </div>

                        <!-- Sort -->
                        <div class="filter-group">
                            <label class="filter-label">Sắp xếp</label>
                            <select name="sortBy" class="filter-select">
                                <option value="newest" selected="@(ViewBag.SortBy == "newest")">Mới nhất</option>
                                <option value="price_asc" selected="@(ViewBag.SortBy == "price_asc")">Giá thấp → cao</option>
                                <option value="price_desc" selected="@(ViewBag.SortBy == "price_desc")">Giá cao → thấp</option>
                                <option value="name_asc" selected="@(ViewBag.SortBy == "name_asc")">Tên A → Z</option>
                            </select>
                        </div>

                        @if (filters != null)
                        {
                            @if (filters.Storages.Any())
                            {
                                <div class="filter-group">
                                    <label class="filter-label">Dung lượng</label>
                                    <div class="filter-options-grid">
                                        @foreach (var s in filters.Storages)
                                        {
                                            <div class="form-check small">
                                                <input class="form-check-input" type="checkbox" id="storage_@s" value="@s">
                                                <label class="form-check-label" for="storage_@s">@s</label>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }

                        <button type="submit" class="btn btn-filter-apply w-100 mt-3">
                            <i class="fas fa-check me-2"></i>Lọc kết quả
                        </button>
                        <a asp-action="Products" class="btn btn-link btn-sm text-center w-100 mt-2 text-decoration-none">Xóa tất cả bộ lọc</a>
                    </form>
                </div>

                <!-- Quick Categories -->
                <div class="filter-header mt-3 rounded-0 border-top border-white border-2">
                    <h6>Khám phá nhanh</h6>
                </div>
                <div class="filter-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var category in ViewBag.Categories)
                        {
                            <a asp-controller="Shop" asp-action="Products" asp-route-categoryId="@category.CategoryId"
                               class="list-group-item list-group-item-action border-0 px-3 py-2 @(ViewBag.CategoryId?.ToString() == category.CategoryId.ToString() ? "active" : "")">
                                <i class="fas fa-@(GetCategoryIcon(category.Name)) me-2"></i>@category.Name
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Products Grid -->
        <div class="col-lg-9">
            <!-- Toolbar -->
            <div class="products-toolbar products-toolbar-premium mb-4">
                <div class="toolbar-info">
                    <span class="results-count">@Model.TotalCount sản phẩm được tìm thấy</span>
                </div>
                <div class="toolbar-actions d-flex gap-3">
                    <div class="view-switch d-none d-md-flex gap-2">
                        <button id="viewGrid" class="btn btn-sm btn-outline-secondary active" title="Xem dạng lưới"><i class="fas fa-th"></i></button>
                        <button id="viewList" class="btn btn-sm btn-outline-secondary" title="Xem dạng danh sách"><i class="fas fa-list"></i></button>
                    </div>
                </div>
            </div>

            @if (Model.Any())
            {
                <div class="row g-4 view-mode-grid" id="productsGrid">
                    @{ var staggerIndex = 0; }
                    @foreach (var product in Model)
                    {
                        <div class="product-item-container col-lg-3 col-md-4 col-sm-6 mb-4 js-stagger-card" data-stagger-index="@staggerIndex">
                            @await Html.PartialAsync("Partials/_ProductCard", product)
                        </div>
                        staggerIndex++;
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-5">
                        <ul class="pagination pagination-rounded justify-content-center">
                            @if (Model.HasPrevious)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-route-search="@ViewBag.Search" asp-route-categoryId="@ViewBag.CategoryId"
                                       asp-route-sortBy="@ViewBag.SortBy" asp-route-minPrice="@ViewBag.MinPrice" 
                                       asp-route-maxPrice="@ViewBag.MaxPrice" asp-route-filter="@ViewBag.Filter" asp-route-page="@(Model.CurrentPage - 1)">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>
                            }

                            @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-route-search="@ViewBag.Search" asp-route-categoryId="@ViewBag.CategoryId"
                                       asp-route-sortBy="@ViewBag.SortBy" asp-route-minPrice="@ViewBag.MinPrice" 
                                       asp-route-maxPrice="@ViewBag.MaxPrice" asp-route-filter="@ViewBag.Filter" asp-route-page="@i">@i</a>
                                </li>
                            }

                            @if (Model.HasNext)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-route-search="@ViewBag.Search" asp-route-categoryId="@ViewBag.CategoryId"
                                       asp-route-sortBy="@ViewBag.SortBy" asp-route-minPrice="@ViewBag.MinPrice" 
                                       asp-route-maxPrice="@ViewBag.MaxPrice" asp-route-filter="@ViewBag.Filter" asp-route-page="@(Model.CurrentPage + 1)">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="empty-state text-center py-5">
                    <div class="empty-icon-wrapper mb-4">
                        <i class="fas fa-search-minus fa-4x text-muted opacity-25"></i>
                    </div>
                    <h4>Không tìm thấy sản phẩm phù hợp</h4>
                    <p class="text-muted">Thử điều chỉnh bộ lọc hoặc từ khóa tìm kiếm của bạn</p>
                    <a asp-action="Products" class="btn btn-primary mt-3">Xóa tất cả bộ lọc</a>
                </div>
            }
        </div>
    </div>
</div>
</div>

@section Scripts {
    <link rel="stylesheet" href="~/css/homepage.css" />
    <script>
        (function () {
            var cards = document.querySelectorAll('.js-stagger-card');
            if (!cards.length) {
                return;
            }

            cards.forEach(function (card) {
                var index = Number(card.getAttribute('data-stagger-index') || 0);
                card.classList.add('stagger-ready');
                card.style.transitionDelay = (Math.min(index % 6, 5) * 70) + 'ms';
            });

            if (!('IntersectionObserver' in window)) {
                cards.forEach(function (card) {
                    card.classList.add('is-visible');
                });
                return;
            }

            var observer = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                        observer.unobserve(entry.target);
                    }
                });
            }, {
                root: null,
                rootMargin: '0px 0px -10% 0px',
                threshold: 0.16
            });

            cards.forEach(function (card) {
                observer.observe(card);
            });

            // View Switcher Logic
            const gridBtn = document.getElementById('viewGrid');
            const listBtn = document.getElementById('viewList');
            const productsGrid = document.getElementById('productsGrid');

            if (gridBtn && listBtn && productsGrid) {
                gridBtn.addEventListener('click', function() {
                    productsGrid.classList.remove('view-mode-list');
                    productsGrid.classList.add('view-mode-grid');
                    gridBtn.classList.add('active');
                    listBtn.classList.remove('active');
                    
                    // Update classes for grid mode
                    $('.product-item-container').removeClass('col-12').addClass('col-lg-3 col-md-4 col-sm-6');
                    localStorage.setItem('productViewMode', 'grid');
                });

                listBtn.addEventListener('click', function() {
                    productsGrid.classList.remove('view-mode-grid');
                    productsGrid.classList.add('view-mode-list');
                    listBtn.classList.add('active');
                    gridBtn.classList.remove('active');
                    
                    // Update classes for list mode
                    $('.product-item-container').removeClass('col-lg-3 col-md-4 col-sm-6').addClass('col-12');
                    localStorage.setItem('productViewMode', 'list');
                });

                // Restore preference
                const savedMode = localStorage.getItem('productViewMode');
                if (savedMode === 'list') {
                    listBtn.click();
                }
            }
        })();
    </script>
}

@functions {
    public string GetCategoryIcon(string name)
    {
        if (string.IsNullOrEmpty(name)) return "cube";
        name = name.ToLower();
         if (name.Contains("điện thoại") || name.Contains("dien thoai") || name.Contains("phone") || name.Contains("iphone") || name.Contains("samsung") || name.Contains("xiaomi"))
             return "mobile-alt";
         if (name.Contains("laptop") || name.Contains("máy tính") || name.Contains("may tinh") || name.Contains("macbook") || name.Contains("dell") || name.Contains("hp"))
             return "laptop";
         if (name.Contains("tablet") || name.Contains("ipad"))
             return "tablet-alt";
         if (name.Contains("âm thanh") || name.Contains("am thanh") || name.Contains("tai nghe") || name.Contains("tái nghe") || name.Contains("headphone") || name.Contains("airpod"))
             return "headphones-alt";
         if (name.Contains("đồng hồ") || name.Contains("dong ho") || name.Contains("watch") || name.Contains("smartwatch"))
             return "clock";
         if (name.Contains("phụ kiện") || name.Contains("phu kien") || name.Contains("accessory") || name.Contains("sạc") || name.Contains("sac") || name.Contains("cable"))
             return "plug";
         if (name.Contains("camera") || name.Contains("webcam"))
             return "camera";
         if (name.Contains("game") || name.Contains("console"))
             return "gamepad";
         if (name.Contains("bàn phím") || name.Contains("ban phim") || name.Contains("keyboard"))
             return "keyboard";
         if (name.Contains("chuột") || name.Contains("chuot") || name.Contains("mouse"))
            return "mouse";
        return "cube";
    }
}
