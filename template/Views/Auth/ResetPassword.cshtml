@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "_AuthLayout";
    var token = ViewBag.Token ?? "";
    var email = ViewBag.Email ?? "";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo">
                <div class="auth-icon-wrapper auth-icon-reset">
                    <i class="fas fa-lock-open"></i>
                </div>
                <h2 class="auth-title">Đặt lại mật khẩu</h2>
                <p class="auth-subtitle">Nhập mật khẩu mới cho tài khoản của bạn</p>
            </div>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert-msg alert-danger-msg">
                <i class="fas fa-exclamation-triangle"></i>@TempData["Error"]
            </div>
        }

        <form method="post" asp-action="ResetPassword" class="auth-form" id="resetPasswordForm">
            @Html.AntiForgeryToken()

            <input type="hidden" name="email" value="@email" />
            <input type="hidden" name="token" value="@token" />

            <div class="input-group-custom mb-3">
                <div class="input-icon-wrapper">
                    <i class="fas fa-lock"></i>
                </div>
                <input name="newPassword" type="password" class="input-with-icon" id="newPassword"
                       placeholder="Mật khẩu mới (tối thiểu 6 ký tự)" required minlength="6" />
            </div>

            <div class="input-group-custom mb-3">
                <div class="input-icon-wrapper">
                    <i class="fas fa-lock"></i>
                </div>
                <input name="confirmPassword" type="password" class="input-with-icon" id="confirmPassword"
                       placeholder="Xác nhận mật khẩu mới" required minlength="6" />
            </div>

            <div id="passwordMismatchError" class="alert-msg alert-danger-msg" style="display:none;">
                <i class="fas fa-exclamation-triangle"></i><span>Mật khẩu xác nhận không khớp</span>
            </div>

            <button type="submit" class="btn btn-auth-submit btn-reset-submit mb-3" id="submitBtn">
                <i class="fas fa-check"></i>Đặt lại mật khẩu
            </button>

            <div class="text-center">
                <p class="auth-form-footer mb-0">Đã nhớ mật khẩu?
                    <a asp-action="Login" class="text-link">
                        Đăng nhập ngay
                    </a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('resetPasswordForm').addEventListener('submit', function (e) {
            e.preventDefault();

            var form = document.getElementById('resetPasswordForm');
            var submitBtn = document.getElementById('submitBtn');
            var originalText = submitBtn.innerHTML;
            var newPassword = document.getElementById('newPassword').value;
            var confirmPassword = document.getElementById('confirmPassword').value;
            var mismatchError = document.getElementById('passwordMismatchError');

            mismatchError.style.display = 'none';

            if (newPassword.length < 6) {
                showError('Mật khẩu mới phải có ít nhất 6 ký tự');
                return;
            }

            if (newPassword !== confirmPassword) {
                mismatchError.style.display = 'flex';
                document.getElementById('confirmPassword').focus();
                return;
            }

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...';

            var formData = new FormData(form);
            var csrfToken = form.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': csrfToken
                }
            }).then(function (res) {
                if (!res.ok) throw new Error('Server error: ' + res.status);
                return res.json();
            }).then(function (data) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;

                clearAlerts();

                if (data.success) {
                    showSuccessCard(data.message || 'Đặt lại mật khẩu thành công!');
                } else {
                    showError(data.error || 'Có lỗi xảy ra, vui lòng thử lại');
                }
            }).catch(function (error) {
                console.error('Reset password error:', error);
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                showError('Có lỗi xảy ra, vui lòng thử lại sau');
            });
        });

        function showError(msg) {
            clearAlerts();
            var alertHtml = '<div class="alert-msg alert-danger-msg" id="tempAlert"><i class="fas fa-exclamation-triangle"></i>' + escapeHtml(msg) + '</div>';
            var form = document.getElementById('resetPasswordForm');
            form.insertBefore(createElementFromHTML(alertHtml), form.firstChild);
        }

        function showSuccessCard(msg) {
            var successCard = document.createElement('div');
            successCard.className = 'reset-success-card';
            successCard.innerHTML = '<div class="reset-success-icon"><i class="fas fa-shield-check"></i></div>' +
                '<h3 class="reset-success-title">Đặt lại mật khẩu thành công!</h3>' +
                '<p class="reset-success-text">' + escapeHtml(msg) + '</p>' +
                '<a href="@Url.Action("Login", "Auth")" class="btn btn-auth-submit btn-login-redirect"><i class="fas fa-sign-in-alt me-2"></i>Đăng nhập ngay</a>';

            var form = document.getElementById('resetPasswordForm');
            form.style.display = 'none';
            form.parentNode.insertBefore(successCard, form.nextSibling);
            successCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function clearAlerts() {
            var existing = document.getElementById('tempAlert');
            if (existing) existing.remove();
        }

        function createElementFromHTML(html) {
            var div = document.createElement('div');
            div.innerHTML = html.trim();
            return div.firstChild;
        }

        function escapeHtml(text) {
            if (!text) return '';
            var map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
            return text.replace(/[&<>"']/g, function (m) { return map[m]; });
        }

        // Real-time password match check
        document.getElementById('confirmPassword').addEventListener('input', function () {
            var newPwd = document.getElementById('newPassword').value;
            var confirmPwd = this.value;
            var mismatchError = document.getElementById('passwordMismatchError');

            if (confirmPwd.length > 0 && newPwd !== confirmPwd) {
                mismatchError.style.display = 'flex';
            } else {
                mismatchError.style.display = 'none';
            }
        });
    </script>

    <style>
        .auth-icon-reset {
            background: linear-gradient(135deg, #023E8A 0%, #0077B6 100%);
            box-shadow: 0 8px 25px rgba(2, 62, 138, 0.35);
        }

        .btn-reset-submit {
            background: linear-gradient(135deg, #023E8A 0%, #0077B6 100%);
            box-shadow: 0 4px 15px rgba(2, 62, 138, 0.3);
        }

        .btn-reset-submit:hover {
            background: linear-gradient(135deg, #012a55 0%, #023E8A 100%);
            box-shadow: 0 8px 25px rgba(2, 62, 138, 0.4);
            color: white;
        }

        .reset-success-card {
            text-align: center;
            padding: 32px 20px;
            animation: slideUp 0.5s ease-out;
        }

        .reset-success-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.15), rgba(16, 185, 129, 0.05));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .reset-success-icon i {
            font-size: 2rem;
            color: #10B981;
        }

        .reset-success-title {
            color: #023E8A;
            font-weight: 800;
            margin-bottom: 12px;
            font-size: 1.3rem;
        }

        .reset-success-text {
            color: #5C6B7A;
            font-size: 0.92rem;
            line-height: 1.6;
            margin-bottom: 10px;
        }

        .btn-login-redirect {
            margin-top: 20px;
            background: linear-gradient(135deg, #0077B6 0%, #00B4D8 100%) !important;
            box-shadow: 0 4px 15px rgba(0, 119, 182, 0.3) !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-login-redirect:hover {
            background: linear-gradient(135deg, #005f8a 0%, #0077B6 100%) !important;
            box-shadow: 0 8px 25px rgba(0, 119, 182, 0.4) !important;
            color: white;
        }
    </style>
}
