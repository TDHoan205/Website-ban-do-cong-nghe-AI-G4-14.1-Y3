@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_AuthLayout";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo">
                <div class="auth-icon-wrapper">
                    <i class="fas fa-store"></i>
                </div>
                <h2 class="auth-title">Chào mừng trở lại!</h2>
                <p class="auth-subtitle">Đăng nhập để tiếp tục mua sắm</p>
            </div>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert-msg alert-danger-msg">
                <i class="fas fa-exclamation-triangle"></i>@TempData["Error"]
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert-msg alert-success-msg">
                <i class="fas fa-check-circle"></i>@TempData["Success"]
            </div>
        }

        @if (!string.IsNullOrEmpty(Context.Session.GetString("PendingCartAction")))
        {
            <div class="alert-msg alert-info-auth">
                <i class="fas fa-info-circle"></i>
                <span>Vui lòng đăng nhập để thêm sản phẩm vào giỏ hàng.</span>
            </div>
        }

        <form method="post" asp-action="Login" class="auth-form" id="loginForm"
              onsubmit="return handleLoginSubmit(event);">
            @Html.AntiForgeryToken()
            <div class="input-group-custom mb-3">
                <div class="input-icon-wrapper">
                    <i class="fas fa-user"></i>
                </div>
                <input name="username" class="input-with-icon" id="username" placeholder="Tên đăng nhập hoặc email" required />
            </div>

            <div class="input-group-custom mb-3">
                <div class="input-icon-wrapper">
                    <i class="fas fa-lock"></i>
                </div>
                <input name="password" type="password" class="input-with-icon" id="password" placeholder="Mật khẩu"
                       required />
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check-custom">
                    <input class="form-check-input-custom" type="checkbox" id="rememberMe">
                    <label class="form-check-label-custom" for="rememberMe">
                        Ghi nhớ đăng nhập
                    </label>
                </div>
                <a asp-action="ForgotPassword" class="forgot-link">Quên mật khẩu?</a>
            </div>

            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <button type="submit" class="btn btn-auth-submit mb-3" id="loginBtn">
                <i class="fas fa-sign-in-alt"></i>Đăng nhập
            </button>

            <div class="text-center">
                <p class="auth-form-footer mb-0">Chưa có tài khoản?
                    <a asp-action="Register" class="text-link">
                        Đăng ký ngay
                    </a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // AJAX login để khôi phục cart sau khi đăng nhập
        function handleLoginSubmit(e) {
            e.preventDefault();
            var form = document.getElementById('loginForm');
            var submitBtn = form.querySelector('button[type="submit"]');
            var originalText = submitBtn.innerHTML;

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang xử lý...';

            var formData = new FormData(form);
            var csrfToken = form.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': csrfToken
                }
            }).then(function (res) {
                if (!res.ok) {
                    // Nếu server trả về 400 (AntiForgery fail) hoặc lỗi khác
                    return res.text().then(function(text) {
                        try { return JSON.parse(text); } catch(e) {
                            throw new Error('Server trả về lỗi ' + res.status);
                        }
                    });
                }
                return res.json();
            }).then(function (data) {
                // Đăng nhập thành công
                if (data.success) {
                    // Khôi phục cart trước khi redirect
                    restorePendingCartOnLogin(csrfToken).then(function () {
                        window.location.href = data.redirectUrl;
                    });
                } else {
                    // Đăng nhập thất bại
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                    var errorMsg = data.error || 'Đăng nhập thất bại';
                    var existingError = form.querySelector('.alert-danger-msg');
                    if (existingError) existingError.remove();
                    var alertHtml = '<div class="alert-msg alert-danger-msg"><i class="fas fa-exclamation-triangle"></i>' + errorMsg + '</div>';
                    form.insertBefore(createElementFromHTML(alertHtml), form.firstChild);
                }
            }).catch(function (error) {
                console.error('Login error:', error);
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                var existingError = form.querySelector('.alert-danger-msg');
                if (existingError) existingError.remove();
                var alertHtml = '<div class="alert-msg alert-danger-msg"><i class="fas fa-exclamation-triangle"></i>Có lỗi xảy ra, vui lòng thử lại</div>';
                form.insertBefore(createElementFromHTML(alertHtml), form.firstChild);
            });
            return false;
        }

        function createElementFromHTML(html) {
            var div = document.createElement('div');
            div.innerHTML = html.trim();
            return div.firstChild;
        }

        function restorePendingCartOnLogin(csrfToken) {
            return fetch('@Url.Action("RestorePendingCart", "Shop")', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': csrfToken || ''
                }
            }).then(function (res) { return res.json(); }).catch(function (err) {
                console.warn('Restore cart error:', err);
                return {};
            });
        }
    </script>
}
