@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_AuthLayout";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-logo">
                <div class="auth-icon-wrapper auth-icon-forgot">
                    <i class="fas fa-key"></i>
                </div>
                <h2 class="auth-title">Quên mật khẩu?</h2>
                <p class="auth-subtitle">Nhập email để nhận hướng dẫn đặt lại mật khẩu</p>
            </div>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert-msg alert-danger-msg">
                <i class="fas fa-exclamation-triangle"></i>@TempData["Error"]
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert-msg alert-success-msg">
                <i class="fas fa-check-circle"></i>@TempData["Success"]
            </div>
        }

        <form method="post" asp-action="ForgotPassword" class="auth-form" id="forgotPasswordForm">
            @Html.AntiForgeryToken()

            <div class="input-group-custom mb-4">
                <div class="input-icon-wrapper">
                    <i class="fas fa-envelope"></i>
                </div>
                <input name="email" type="email" class="input-with-icon" id="email" placeholder="Nhập địa chỉ email của bạn" required />
            </div>

            <button type="submit" class="btn btn-auth-submit btn-forgot-submit mb-3" id="submitBtn">
                <i class="fas fa-paper-plane"></i>Gửi yêu cầu
            </button>

            <div class="text-center">
                <p class="auth-form-footer mb-0">Nhớ mật khẩu rồi?
                    <a asp-action="Login" class="text-link">
                        Đăng nhập ngay
                    </a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('forgotPasswordForm').addEventListener('submit', function (e) {
            e.preventDefault();

            var form = document.getElementById('forgotPasswordForm');
            var submitBtn = document.getElementById('submitBtn');
            var originalText = submitBtn.innerHTML;
            var emailInput = document.getElementById('email');
            var email = emailInput.value.trim();

            if (!email || email.indexOf('@@') < 0 || email.indexOf('.') < 0) {
                showError('Vui lòng nhập địa chỉ email hợp lệ');
                return;
            }

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Đang gửi...';

            var formData = new FormData(form);
            var csrfToken = form.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': csrfToken
                }
            }).then(function (res) {
                if (!res.ok) throw new Error('Server error: ' + res.status);
                return res.json();
            }).then(function (data) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;

                clearAlerts();

                if (data.success) {
                    // Show success card
                    var successCard = document.createElement('div');
                    successCard.className = 'forgot-success-card';
                    successCard.innerHTML = '<div class="forgot-success-icon"><i class="fas fa-envelope-open-text"></i></div>' +
                        '<h3 class="forgot-success-title">Kiểm tra hộp thư của bạn!</h3>' +
                        '<p class="forgot-success-text">Chúng tôi đã gửi hướng dẫn đặt lại mật khẩu đến <strong>' + escapeHtml(email) + '</strong>.</p>' +
                        '<p class="forgot-success-text">Nếu không thấy email, vui lòng kiểm tra thư mục <strong>thư rác (spam)</strong>.</p>' +
                        '<a href="@Url.Action("Login", "Auth")" class="btn btn-auth-submit"><i class="fas fa-arrow-left me-2"></i>Quay lại đăng nhập</a>';
                    form.style.display = 'none';
                    form.parentNode.insertBefore(successCard, form.nextSibling);
                } else {
                    showError(data.error || 'Có lỗi xảy ra, vui lòng thử lại');
                }
            }).catch(function (error) {
                console.error('Forgot password error:', error);
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                showError('Có lỗi xảy ra, vui lòng thử lại sau');
            });
        });

        function showError(msg) {
            clearAlerts();
            var alertHtml = '<div class="alert-msg alert-danger-msg" id="tempAlert"><i class="fas fa-exclamation-triangle"></i>' + escapeHtml(msg) + '</div>';
            var form = document.getElementById('forgotPasswordForm');
            form.insertBefore(createElementFromHTML(alertHtml), form.firstChild);
        }

        function clearAlerts() {
            var existing = document.getElementById('tempAlert');
            if (existing) existing.remove();
        }

        function createElementFromHTML(html) {
            var div = document.createElement('div');
            div.innerHTML = html.trim();
            return div.firstChild;
        }

        function escapeHtml(text) {
            var map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
            return text.replace(/[&<>"']/g, function (m) { return map[m]; });
        }
    </script>

    <style>
        .auth-icon-forgot {
            background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
            box-shadow: 0 8px 25px rgba(245, 158, 11, 0.35);
        }

        .btn-forgot-submit {
            background: linear-gradient(135deg, #F59E0B 0%, #FBBF24 100%);
            box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3);
        }

        .btn-forgot-submit:hover {
            background: linear-gradient(135deg, #D97706 0%, #F59E0B 100%);
            box-shadow: 0 8px 25px rgba(245, 158, 11, 0.4);
            color: white;
        }

        .forgot-success-card {
            text-align: center;
            padding: 32px 20px;
            animation: slideUp 0.5s ease-out;
        }

        .forgot-success-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.15), rgba(16, 185, 129, 0.05));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .forgot-success-icon i {
            font-size: 2rem;
            color: #10B981;
        }

        .forgot-success-title {
            color: #023E8A;
            font-weight: 800;
            margin-bottom: 12px;
            font-size: 1.3rem;
        }

        .forgot-success-text {
            color: #5C6B7A;
            font-size: 0.92rem;
            line-height: 1.6;
            margin-bottom: 10px;
        }

        .forgot-success-card .btn-auth-submit {
            margin-top: 20px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
    </style>
}
