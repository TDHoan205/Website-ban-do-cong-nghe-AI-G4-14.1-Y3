@model Webstore.Models.CartItem
@{
    ViewData["Title"] = "Sửa Giỏ Hàng";
    var carts = ViewBag.Carts as List<Webstore.Models.Cart> ?? new List<Webstore.Models.Cart>();
    var products = ViewBag.Products as List<Webstore.Models.Product> ?? new List<Webstore.Models.Product>();
    var variants = ViewBag.Variants as List<Webstore.Models.ProductVariant> ?? new List<Webstore.Models.ProductVariant>();
}

<h2>Sửa Giỏ Hàng</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="CartItemId" />
    <div class="mb-3">
        <label asp-for="CartId" class="form-label">Cart</label>
        <select asp-for="CartId" class="form-select">
            <option value="">-- Chọn cart --</option>
            @foreach (var c in carts)
            {
                <option value="@c.CartId" selected="@(Model.CartId == c.CartId)">#@c.CartId - @(c.Account?.Username ?? "Guest")</option>
            }
        </select>
        <span asp-validation-for="CartId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ProductId" class="form-label">Sản phẩm</label>
        <select asp-for="ProductId" class="form-select">
            <option value="">-- Chọn sản phẩm --</option>
            @foreach (var p in products)
            {
                <option value="@p.ProductId" selected="@(Model.ProductId == p.ProductId)">@p.Name - @p.Price.ToString("N2")</option>
            }
        </select>
        <span asp-validation-for="ProductId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="VariantId" class="form-label">Biến thể</label>
        <select asp-for="VariantId" class="form-select">
            <option value="">-- Không chọn --</option>
            @foreach (var v in variants)
            {
                <option value="@v.VariantId" selected="@(Model.VariantId == v.VariantId)">#@v.VariantId - @v.Color @(!string.IsNullOrEmpty(v.Storage) ? "/ " + v.Storage : "")</option>
            }
        </select>
        <span asp-validation-for="VariantId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Quantity" class="form-label">Số lượng</label>
        <input asp-for="Quantity" class="form-control" type="number" min="1" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="AddedDate" class="form-label">Ngày thêm</label>
        <input asp-for="AddedDate" class="form-control" type="datetime-local" />
        <span asp-validation-for="AddedDate" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Cập nhật</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
