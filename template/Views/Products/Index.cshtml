@model Webstore.Models.PagedList<Webstore.Models.Product>
@{
    ViewData["Title"] = "Quản lý Sản Phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="fas fa-box me-2 text-primary"></i>Quản lý Sản Phẩm
    </h2>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-8">
                <form method="get" asp-action="Index" class="d-flex">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control me-2"
                        placeholder="Tìm theo tên, mô tả, danh mục, nhà cung cấp..." />
                    <input type="hidden" name="sortOrder" value="@ViewBag.SortOrder" />
                    <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search me-1"></i>Tìm kiếm
                    </button>
                </form>
            </div>
            <div class="col-md-4 text-end">
                <a asp-action="Create" class="btn btn-success">
                    <i class="fas fa-plus me-1"></i>Thêm mới
                </a>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<vc:paged-list-pager
    current-page="@Model.CurrentPage"
    total-pages="@Model.TotalPages"
    total-count="@Model.TotalCount"
    page-size="@Model.PageSize"
    has-previous="@Model.HasPrevious"
    has-next="@Model.HasNext"
    search="@ViewBag.Search"
    sort-order="@ViewBag.SortOrder"
    controller-name="Products"
    action-name="Index">
</vc:paged-list-pager>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-scroll-container">
            <table class="table table-hover mb-0 table-zebra">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Ảnh</th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.NameSortParm" asp-route-search="@ViewBag.Search"
                                asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Tên sản phẩm <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.PriceSortParm" asp-route-search="@ViewBag.Search"
                                asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Giá <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.CategorySortParm" asp-route-search="@ViewBag.Search"
                                asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Danh mục <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.SupplierSortParm" asp-route-search="@ViewBag.Search"
                                asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Nhà cung cấp <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th class="text-center">Tồn kho</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ProductId</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name"
                                        style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;" class="shadow-sm" />
                                }
                                else
                                {
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center"
                                        style="width: 50px; height: 50px;">
                                        <i class="fas fa-image text-muted"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <strong>@item.Name</strong>
                                @{ var previewDescription = ProductDescriptionText.ToPlainText(item.Description, 50); }
                                @if (!string.IsNullOrEmpty(previewDescription))
                                {
                                    <br /><small class="text-muted" title="@(ProductDescriptionText.ToPlainText(item.Description))">@(previewDescription)</small>
                                }
                            </td>
                            <td class="fw-bold text-danger">@item.Price.ToString("N0") ₫</td>
                            <td>
                                @if (item.Category != null)
                                {
                                    <span class="badge bg-primary">@item.Category.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.Supplier != null)
                                {
                                    <span class="badge bg-info">@item.Supplier.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center fw-bold @(item.StockQuantity <= 0 ? "text-danger" : item.StockQuantity <= 5 ? "text-warning" : "text-success")">
                                @(item.StockQuantity > 0 ? item.StockQuantity.ToString() : "0")
                            </td>
                            <td class="text-center">
                                @if (item.IsAvailable)
                                {
                                    @if (item.StockQuantity > 0)
                                    {
                                        <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Còn hàng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark"><i class="fas fa-exclamation-triangle me-1"></i>Hết hàng</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="fas fa-eye-slash me-1"></i>Ẩn</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-primary" title="Sửa">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
