@model Webstore.Models.Product
@{
    ViewData["Title"] = "Sửa Sản Phẩm";
    var categories = ViewBag.Categories as List<Webstore.Models.Category> ?? new List<Webstore.Models.Category>();
    var suppliers = ViewBag.Suppliers as List<Webstore.Models.Supplier> ?? new List<Webstore.Models.Supplier>();
    var variants = ViewBag.Variants as List<Webstore.Models.ProductVariant> ?? new List<Webstore.Models.ProductVariant>();
    var productImages = ViewBag.ProductImages as List<Webstore.Models.ProductImage> ?? new List<Webstore.Models.ProductImage>();
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fas fa-edit me-2 text-primary"></i>Sửa Sản Phẩm
        </h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-1"></i>Quay lại
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="productForm">
        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="ImageUrl" />

        <div class="row g-4">
            <!-- LEFT COLUMN: Basic Info -->
            <div class="col-lg-8">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold">
                            <i class="fas fa-info-circle me-2 text-primary"></i>Thông tin cơ bản
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <input asp-for="Price" class="form-control" type="number" step="1000" min="0" />
                                    <span class="input-group-text">VNĐ</span>
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="StockQuantity" class="form-label fw-semibold">Số lượng trong kho</label>
                                <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                                <small class="text-muted">Tổng số lượng tất cả các phiên bản</small>
                                <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="CategoryId" class="form-label fw-semibold">Danh mục</label>
                                <select asp-for="CategoryId" class="form-select">
                                    <option value="">-- Không chọn --</option>
                                    @foreach (var c in categories)
                                    {
                                        <option value="@c.CategoryId" selected="@(Model.CategoryId == c.CategoryId)">@c.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="SupplierId" class="form-label fw-semibold">Nhà cung cấp</label>
                                <select asp-for="SupplierId" class="form-select">
                                    <option value="">-- Không chọn --</option>
                                    @foreach (var s in suppliers)
                                    {
                                        <option value="@s.SupplierId" selected="@(Model.SupplierId == s.SupplierId)">@s.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Product Options -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold">
                            <i class="fas fa-cog me-2 text-primary"></i>Tùy chọn sản phẩm
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <div class="form-check">
                                    <input asp-for="IsAvailable" class="form-check-input" id="IsAvailableCheck" />
                                    <label for="IsAvailableCheck" class="form-check-label fw-semibold">
                                        <strong>Còn hàng</strong>
                                    </label>
                                </div>
                                <small class="text-muted">Hiển thị cho khách hàng</small>
                            </div>
                            <div class="col-md-3">
                                <div class="form-check">
                                    <input asp-for="IsNew" class="form-check-input" id="IsNewCheck" />
                                    <label for="IsNewCheck" class="form-check-label fw-semibold">Sản phẩm mới</label>
                                </div>
                                <small class="text-muted">Hiển thị badge "Mới"</small>
                            </div>
                            <div class="col-md-3">
                                <div class="form-check">
                                    <input asp-for="IsHot" class="form-check-input" id="IsHotCheck" />
                                    <label for="IsHotCheck" class="form-check-label fw-semibold">Sản phẩm hot</label>
                                </div>
                                <small class="text-muted">Hiển thị badge "Hot"</small>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-2">
                                    <label asp-for="DiscountPercent" class="form-label fw-semibold small mb-1">Giảm giá (%)</label>
                                    <input asp-for="DiscountPercent" class="form-control form-control-sm" type="number" min="0" max="100" placeholder="0" />
                                </div>
                            </div>
                        </div>

                        @if (Model.StockQuantity <= 0)
                        {
                            <div class="mt-3">
                                <div class="alert alert-warning mb-0 py-2">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    <strong>Cảnh báo:</strong> Số lượng trong kho = 0. Vui lòng cập nhật hoặc bỏ chọn "Còn hàng".
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Product Variants & Images -->
                @await Html.PartialAsync("Partials/_ProductVariants", variants)
            </div>

            <!-- RIGHT COLUMN: Images -->
            <div class="col-lg-4">
                <!-- Main Product Image -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 fw-bold">
                            <i class="fas fa-image me-2 text-primary"></i>Ảnh đại diện
                        </h5>
                    </div>
                    <div class="card-body text-center">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-3">
                                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-thumbnail" style="max-height: 200px; object-fit: contain;" />
                                <p class="text-muted small mt-1 mb-0">Ảnh đại diện hiện tại</p>
                            </div>
                        }
                        else
                        {
                            <div class="bg-light rounded p-4 mb-3">
                                <i class="fas fa-image fa-4x text-secondary opacity-25"></i>
                                <p class="text-muted mt-2 mb-0 small">Chưa có ảnh đại diện</p>
                            </div>
                        }
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        <div class="mt-2 text-start">
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                Kích thước tối ưu: <strong>800x800px</strong> (vuông).
                                Định dạng: JPG, PNG, WebP.
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Gallery Images -->
                @if (productImages.Any())
                {
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-white py-3">
                            <h5 class="mb-0 fw-bold">
                                <i class="fas fa-images me-2 text-primary"></i>Thư viện ảnh (@productImages.Count)
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var img in productImages)
                                {
                                    <div class="position-relative">
                                        <img src="@img.ImageUrl" alt="ảnh"
                                             style="width:72px;height:72px;object-fit:cover;border-radius:8px;border:2px solid @(img.IsPrimary ? "var(--bs-primary)" : "#dee2e6");"
                                             onerror="this.src='/images/products/placeholder.svg'" />
                                        @if (img.IsPrimary)
                                        {
                                            <span class="badge bg-primary position-absolute"
                                                  style="font-size:8px;top:-4px;left:-4px;padding:2px 4px;">Chính</span>
                                        }
                                    </div>
                                }
                            </div>
                            <small class="text-muted mt-2 d-block">
                                <i class="fas fa-info-circle me-1"></i>
                                Quản lý ảnh chi tiết bên dưới trong phần "Phiên bản sản phẩm & Hình ảnh"
                            </small>
                        </div>
                    </div>
                }

                <!-- Submit -->
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="fas fa-save me-2"></i>Cập nhật sản phẩm
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-times me-2"></i>Hủy bỏ
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
