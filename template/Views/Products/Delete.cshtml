@model Webstore.Models.Product
@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<h2>Xóa Sản Phẩm</h2>

<div class="alert alert-warning">Bạn có chắc chắn muốn xóa sản phẩm này?</div>

<dl class="row">
    <dt class="col-sm-2">ID</dt>
    <dd class="col-sm-10">@Model.ProductId</dd>
    <dt class="col-sm-2">Tên</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Giá</dt>
    <dd class="col-sm-10">@Model.Price.ToString("N2")</dd>
    <dt class="col-sm-2">Danh mục</dt>
    <dd class="col-sm-10">@Model.Category?.Name</dd>
    <dt class="col-sm-2">Nhà cung cấp</dt>
    <dd class="col-sm-10">@Model.Supplier?.Name</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ProductId" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>

