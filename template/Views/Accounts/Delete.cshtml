@model Webstore.Models.Account
@{
    ViewData["Title"] = "Xóa Tài Khoản";
}

<h2>Xóa Tài Khoản</h2>

<div class="alert alert-warning">Bạn có chắc chắn muốn xóa tài khoản này?</div>

<dl class="row">
    <dt class="col-sm-2">ID</dt>
    <dd class="col-sm-10">@Model.AccountId</dd>
    <dt class="col-sm-2">Username</dt>
    <dd class="col-sm-10">@Model.Username</dd>
    <dt class="col-sm-2">Họ tên</dt>
    <dd class="col-sm-10">@Model.FullName</dd>
    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.Email</dd>
    <dt class="col-sm-2">Vai trò</dt>
    <dd class="col-sm-10">@Model.RoleName</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="AccountId" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>

