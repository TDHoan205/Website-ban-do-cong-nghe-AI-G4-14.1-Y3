@model Webstore.Models.PagedList<Webstore.Models.Inventory>
@{
    ViewData["Title"] = "Quản lý Tồn Kho";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="fas fa-warehouse me-2 text-primary"></i>Quản lý Tồn Kho
    </h2>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-8">
                <form method="get" asp-action="Index" class="d-flex">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control me-2" placeholder="Tìm theo tên sản phẩm..." />
                    <input type="hidden" name="sortOrder" value="@ViewBag.SortOrder" />
                    <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search me-1"></i>Tìm kiếm
                    </button>
                </form>
            </div>
            <div class="col-md-4 text-end">
                <a asp-action="Create" class="btn btn-success">
                    <i class="fas fa-plus me-1"></i>Thêm mới
                </a>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<vc:paged-list-pager
    current-page="@Model.CurrentPage"
    total-pages="@Model.TotalPages"
    total-count="@Model.TotalCount"
    page-size="@Model.PageSize"
    has-previous="@Model.HasPrevious"
    has-next="@Model.HasNext"
    search="@ViewBag.Search"
    sort-order="@ViewBag.SortOrder"
    controller-name="Inventory"
    action-name="Index">
</vc:paged-list-pager>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-scroll-container">
            <table class="table table-hover mb-0 table-zebra">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.ProductSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Sản phẩm <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.QuantitySortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Số lượng tồn <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewBag.DateSortParm" asp-route-search="@ViewBag.Search" asp-route-pageSize="@ViewBag.PageSize" class="text-white text-decoration-none">
                                Cập nhật lần cuối <i class="fas fa-sort ms-1"></i>
                            </a>
                        </th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.InventoryId</td>
                            <td>
                                <strong>@(item.Product?.Name ?? "N/A")</strong>
                                @if (!string.IsNullOrEmpty(item.Product?.Description))
                                {
                                    <br /><small class="text-muted">@ProductDescriptionText.ToPlainText(item.Product.Description)</small>
                                }
                            </td>
                            <td>
                                @{
                                    var stockClass = item.StockQuantity > 10 ? "bg-success" : item.StockQuantity > 0 ? "bg-warning text-dark" : "bg-danger";
                                    var stockIcon = item.StockQuantity > 10 ? "fa-check-circle" : item.StockQuantity > 0 ? "fa-exclamation-triangle" : "fa-times-circle";
                                }
                                <span class="badge @stockClass">
                                    <i class="fas @stockIcon me-1"></i>@item.StockQuantity
                                </span>
                                @if (item.StockQuantity <= 5 && item.StockQuantity > 0)
                                {
                                    <span class="badge bg-danger ms-1">Sắp hết</span>
                                }
                                else if (item.StockQuantity == 0)
                                {
                                    <span class="badge bg-dark ms-1">Hết hàng</span>
                                }
                            </td>
                            <td>
                                <i class="fas fa-clock text-muted me-1"></i>
                                @item.LastUpdated.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.InventoryId" class="btn btn-sm btn-primary" title="Sửa">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.InventoryId" class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
